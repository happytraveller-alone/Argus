# =============================================
# Argus dedicated LLM environment template
# =============================================
# Normal users usually only edit this file after bootstrap copies it to
# .argus-llm.env.
#
# Validate before startup:
#   ./scripts/validate-llm-config.sh --env-file ./.argus-llm.env
#   ./argus-bootstrap.sh

# ── Primary model (used for intelligent audit pipeline) ──────────────
LLM_PROVIDER=openai_compatible
LLM_API_KEY=sk-your-api-key
LLM_MODEL=
LLM_BASE_URL=
LLM_TIMEOUT=150
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
# Optional advanced LLM timeouts/headers.
LLM_FIRST_TOKEN_TIMEOUT=180
LLM_STREAM_TIMEOUT=180
# LLM_CUSTOM_HEADERS={"X-Custom":"value"}

# ── Secondary model (used for CodeQL compile exploration) ────────────
# If not set, falls back to the primary model above.
# CODEQL_LLM_PROVIDER=openai_compatible
# CODEQL_LLM_API_KEY=sk-your-api-key
# CODEQL_LLM_MODEL=
# CODEQL_LLM_BASE_URL=
# CODEQL_LLM_TIMEOUT=60
# CODEQL_LLM_TEMPERATURE=0.0
# CODEQL_LLM_MAX_TOKENS=2048

# ── Fallback model (used when primary model fails) ───────────────────
# If not set, no fallback is attempted.
# FALLBACK_LLM_PROVIDER=openai_compatible
# FALLBACK_LLM_API_KEY=sk-your-api-key
# FALLBACK_LLM_MODEL=
# FALLBACK_LLM_BASE_URL=

# Optional agent-level timeout imported with the LLM config.
AGENT_TIMEOUT=1800
