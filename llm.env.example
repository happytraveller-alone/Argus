# =============================================================
#  Argus dedicated LLM environment template
# =============================================================
#
# Define N >= 1 LLM configurations. The backend imports all
# candidates, tests connectivity to each, and uses the first
# passing one as the active default. Failed candidates are
# preserved in the backend DB but not activated.
#
# Validate before startup:
#   ./scripts/validate-llm-config.sh --env-file ./.argus-llm.env
#   ./argus-bootstrap.sh
#
# Precedence:
#   - Numbered prefix (LLM_1_*, LLM_2_*, ...) is canonical.
#   - Bare LLM_PROVIDER=... (no number) is auto-promoted to
#     LLM_1_* only when no numbered config is present.
#   - When BOTH bare and numbered are set, the numbered prefix
#     WINS; bare keys are silently dropped.
#
# AGENT_TIMEOUT is GLOBAL (single value, not per-row).
# Per-row LLM_N_AGENT_TIMEOUT is silently ignored.

# -- Config 1 (primary candidate) -----------------------------
LLM_1_PROVIDER=openai_compatible
LLM_1_API_KEY=sk-your-api-key
LLM_1_MODEL=
LLM_1_BASE_URL=
LLM_1_TIMEOUT=150
LLM_1_TEMPERATURE=0.0
LLM_1_MAX_TOKENS=40960
# LLM_1_FIRST_TOKEN_TIMEOUT=180
# LLM_1_STREAM_TIMEOUT=180
# LLM_1_CUSTOM_HEADERS={"X-Custom":"value"}

# -- Config 2 (fallback candidate) ----------------------------
# Uncomment and fill in to enable a second candidate.
# LLM_2_PROVIDER=anthropic_compatible
# LLM_2_API_KEY=sk-your-api-key
# LLM_2_MODEL=
# LLM_2_BASE_URL=
# LLM_2_TIMEOUT=150
# LLM_2_TEMPERATURE=0.0
# LLM_2_MAX_TOKENS=40960

# -- Global agent timeout (not per-row) ----------------------
AGENT_TIMEOUT=1800
