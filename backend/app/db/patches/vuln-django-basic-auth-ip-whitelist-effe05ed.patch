From effe05ed1ed9e1ccc675a65b69d36217e5c5dfc6 Mon Sep 17 00:00:00 2001
From: Tomasz Knapik <hi@tmkn.org>
Date: Sat, 20 Jun 2020 00:45:10 +0100
Subject: [PATCH] Fix potential timing attack on basic authentication

---
 CHANGELOG.rst     | 5 +++++
 CONTRIBUTORS.txt  | 1 +
 baipw/__init__.py | 2 +-
 baipw/utils.py    | 5 ++++-
 4 files changed, 11 insertions(+), 2 deletions(-)

diff --git a/CHANGELOG.rst b/CHANGELOG.rst
index 105f4f1..1bb9836 100644
--- a/CHANGELOG.rst
+++ b/CHANGELOG.rst
@@ -1,3 +1,8 @@
+0.3.4 - XXXXXXXXXXXXXXXXXX
+--------------------------
+
+* Fix potential timing attack if basic authentication is enabled (GHSA-m38j-pmg3-v5x5)
+
 0.3.3 - 20th February 2020
 ~~~~~~~~~~~~~~~~~~~~~~~~~~
 
diff --git a/CONTRIBUTORS.txt b/CONTRIBUTORS.txt
index a8b817f..009125d 100644
--- a/CONTRIBUTORS.txt
+++ b/CONTRIBUTORS.txt
@@ -5,3 +5,4 @@ Todd Dembrey
 Kevin Howbrook
 Karl Hobley
 Balazs Endresz
+Thibaud Colas
diff --git a/baipw/__init__.py b/baipw/__init__.py
index e19434e..334b899 100644
--- a/baipw/__init__.py
+++ b/baipw/__init__.py
@@ -1 +1 @@
-__version__ = "0.3.3"
+__version__ = "0.3.4"
diff --git a/baipw/utils.py b/baipw/utils.py
index 6432022..e2b921b 100644
--- a/baipw/utils.py
+++ b/baipw/utils.py
@@ -1,6 +1,7 @@
 import base64
 
 from django.conf import settings
+from django.utils.crypto import constant_time_compare
 
 from .exceptions import Unauthorized
 
@@ -57,6 +58,8 @@ def authorize(request, configured_username, configured_password):
         raise Unauthorized('"Basic" is not an authorization method.')
     auth = base64.b64decode(auth.strip()).decode("utf-8")
     username, password = auth.split(":", 1)
-    if username == configured_username and password == configured_password:
+    username_valid = constant_time_compare(username, configured_username)
+    password_valid = constant_time_compare(password, configured_password)
+    if username_valid & password_valid:
         return True
     raise Unauthorized("Basic authentication credentials are invalid.")
-- 
2.34.1

