From ea13945f3c2dc2c21e30e2731bf2782384307a13 Mon Sep 17 00:00:00 2001
From: Aurelien David <aurelien.david@telecom-paristech.fr>
Date: Mon, 17 Dec 2018 12:05:16 +0100
Subject: [PATCH] heap overflow in audio_sample_entry_AddBox? (#1180)

---
 src/isomedia/box_code_base.c | 5 ++---
 1 file changed, 2 insertions(+), 3 deletions(-)

diff --git a/src/isomedia/box_code_base.c b/src/isomedia/box_code_base.c
index 5a47a55af..f0de8dc4d 100644
--- a/src/isomedia/box_code_base.c
+++ b/src/isomedia/box_code_base.c
@@ -3931,9 +3931,8 @@ GF_Err audio_sample_entry_AddBox(GF_Box *s, GF_Box *a)
             //unknown fomat, look for 'es' (esds) and try to parse box
             else if (wave->data != NULL) {
                 u32 offset = 0;
-                while ((wave->data[offset + 4] != 'e') && (wave->data[offset + 5] != 's')) {
+                while (offset + 5 < wave->dataSize && (wave->data[offset + 4] != 'e') && (wave->data[offset + 5] != 's')) {
                     offset++;
-                    if (offset == wave->dataSize) break;
                 }
                 if (offset < wave->dataSize) {
                     GF_Box *a;
@@ -5066,7 +5065,7 @@ void stbl_del(GF_Box *s)
 		if (ptr->traf_map->sample_num) gf_free(ptr->traf_map->sample_num);
 		gf_free(ptr->traf_map);
 	}
-	
+
 	gf_free(ptr);
 }
 
