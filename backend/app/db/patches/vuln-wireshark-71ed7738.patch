 tshark.c                  |  8 +++----
 ui/gtk/capture_file_dlg.c | 14 ++++++------
 ui/gtk/print_dlg.c        | 14 ++++++------
 ui/win32/file_dlg_win32.c | 18 +++++++---------
 10 files changed, 76 insertions(+), 62 deletions(-)

