From d367309d4427c2d651b0f0b304504cf59c056cab Mon Sep 17 00:00:00 2001
From: Alex McHardy <amchardy@shutterstock.com>
Date: Thu, 13 Oct 2016 13:37:30 -0600
Subject: [PATCH] Make interpolation.escapeValue always default to true

---
 src/Interpolator.js | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/Interpolator.js b/src/Interpolator.js
index 89eb3df..9610aa8 100644
--- a/src/Interpolator.js
+++ b/src/Interpolator.js
@@ -17,7 +17,7 @@ class Interpolator {
 
     const iOpts = options.interpolation;
 
-    this.escapeValue = iOpts.escapeValue;
+    this.escapeValue = iOpts.escapeValue !== undefined ? iOpts.escapeValue : true;
 
     this.prefix = iOpts.prefix ? utils.regexEscape(iOpts.prefix) : iOpts.prefixEscaped || '{{';
     this.suffix = iOpts.suffix ? utils.regexEscape(iOpts.suffix) : iOpts.suffixEscaped || '}}';
-- 
