From 870d518f7de349c3fa4c7b9883789fdca4590c4e Mon Sep 17 00:00:00 2001
From: Paco Avila <pavila@openkm.com>
Date: Tue, 6 Sep 2022 09:21:42 +0200
Subject: [PATCH] Reported XSS vulnerability

Fix #333
---
 src/main/java/com/openkm/util/FormatUtil.java | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/src/main/java/com/openkm/util/FormatUtil.java b/src/main/java/com/openkm/util/FormatUtil.java
index 6918fbd..bb9af86 100644
--- a/src/main/java/com/openkm/util/FormatUtil.java
+++ b/src/main/java/com/openkm/util/FormatUtil.java
@@ -195,6 +195,9 @@ public class FormatUtil {
 				.replaceAll("(?i)<.*?javascript:.*?>.*?</.*?>", "") // case 2 - Open and close
 				.replaceAll("(?i)<.*?javascript:.*?/>", "") // case 2 - Open / close
 				.replaceAll("(?i)<.*?javascript:.*?>", "") // case 2 - Open and !close
+				.replaceAll("(?i)<.*?javascript&colon;.*?>.*?</.*?>", "") // case 2.5 - Open and close
+				.replaceAll("(?i)<.*?javascript&colon;.*?/>", "") // case 2.5 - Open / close
+				.replaceAll("(?i)<.*?javascript&colon;.*?>", "") // case 2.5 - Open and !close
 				.replaceAll("(?i)<.*?\\s+on.*?>.*?</.*?>", "") // case 3 - Open and close
 				.replaceAll("(?i)<.*?\\s+on.*?/>", "") // case 3 - Open / close
 				.replaceAll("(?i)<.*?\\s+on.*?>", ""); // case 3 - Open and !close
-- 
2.34.1

