From e22260083e2ae35ae7d57fa5632a9c49db3ce849 Mon Sep 17 00:00:00 2001
From: Michiel Dethmers <git@phplist.com>
Date: Tue, 26 May 2020 22:08:48 +0100
Subject: [PATCH] validate input on edit attribute values

---
 public_html/lists/admin/editattributes.php | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/public_html/lists/admin/editattributes.php b/public_html/lists/admin/editattributes.php
index d2aae606..084f5a53 100644
--- a/public_html/lists/admin/editattributes.php
+++ b/public_html/lists/admin/editattributes.php
@@ -71,7 +71,7 @@ switch ($data['type']) {
                 $listorder = $maxitem[0] + 1; // One more than the maximum
             }
             foreach ($items as $key => $val) {
-                $val = clean($val);
+                $val = strip_tags($val);
                 if ($val != '') {
                     $query = sprintf('insert into %s (name,listorder) values("%s","%s")', $table, $val, $listorder);
                     $result = Sql_query($query);
@@ -209,7 +209,7 @@ switch ($data['type']) {
                 printf(' <input type="text" name="listorder[%d]" value="%s" size="5" class="listorder" />', $row['id'],
                     $row['listorder']);
             }
-            printf(' %s %s </div>', $row['name'],
+            printf(' %s %s </div>', htmlspecialchars($row['name']),
                 ($row['name'] == $data['default_value']) ? '('.$GLOBALS['I18N']->get('default').')' : '');
         }
         if ($num && $num < ATTRIBUTEVALUE_REORDER_LIMIT) {
-- 
