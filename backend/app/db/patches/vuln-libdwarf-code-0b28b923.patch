diff --git a/dwarfdump/sanitized.c b/dwarfdump/sanitized.c
new file mode 100644
index 00000000..1e109a4b
--- /dev/null
+++ b/dwarfdump/sanitized.c
@@ -0,0 +1,144 @@
+/*
