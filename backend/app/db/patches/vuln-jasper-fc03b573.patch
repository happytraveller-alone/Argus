Subject: [PATCH] Back out change to jpc_t1cod.c since it only masks an
 existing bug but does not actually fix it.

---
 src/libjasper/jpc/jpc_t1cod.c | 3 +--
 1 file changed, 1 insertion(+), 2 deletions(-)

diff --git a/src/libjasper/jpc/jpc_t1cod.c b/src/libjasper/jpc/jpc_t1cod.c
index 1b65c6e..db7a788 100644
--- a/src/libjasper/jpc/jpc_t1cod.c
+++ b/src/libjasper/jpc/jpc_t1cod.c
@@ -210,8 +210,7 @@ int JPC_SEGPASSCNT(int passno, int firstpassno, int numpasses, int bypass, int t
 	} else {
 		ret = JPC_PREC * 3 - 2;
 	}
-	if (passno < numpasses)
-		ret = JAS_MIN(ret, numpasses - passno);
+	ret = JAS_MIN(ret, numpasses - passno);
 	return ret;
 }
 
