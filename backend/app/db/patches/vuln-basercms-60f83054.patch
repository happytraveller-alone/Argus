From 60f83054d8131b0ace60716cec7e629b5eb3a8f0 Mon Sep 17 00:00:00 2001
From: gondoh <gondoh@catchup.co.jp>
Date: Mon, 27 Feb 2023 17:25:17 +0900
Subject: [PATCH] fix CVE-2023-25654
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

ファイル更新時のValidationを改善
---
 lib/Baser/Model/BcAppModel.php | 20 ++++++++++++++------
 1 file changed, 14 insertions(+), 6 deletions(-)

diff --git a/lib/Baser/Model/BcAppModel.php b/lib/Baser/Model/BcAppModel.php
index ef6eefa95..b7f967bb6 100755
--- a/lib/Baser/Model/BcAppModel.php
+++ b/lib/Baser/Model/BcAppModel.php
@@ -932,14 +932,22 @@ class BcAppModel extends Model
 	public function fileExt($check, $exts)
 	{
 		$file = $check[key($check)];
+		if (!is_array($exts)) {
+			$exts = explode(',', $exts);
+		}
+
+		// FILES形式のチェック
 		if (!empty($file['name'])) {
-			if (!is_array($exts)) {
-				$exts = explode(',', $exts);
-			}
 			$ext = decodeContent($file['type'], $file['name']);
-			if (in_array($ext, $exts)) {
-				return true;
-			} else {
+			if (!in_array($ext, $exts)) {
+				return false;
+			}
+		}
+
+		// 更新時の文字列チェック
+		if (is_string($file)) {
+			$ext = pathinfo($file, PATHINFO_EXTENSION);
+			if (!in_array($ext, $exts)) {
 				return false;
 			}
 		}
-- 
