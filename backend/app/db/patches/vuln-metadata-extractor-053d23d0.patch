+        reader.skip(8); // reserved
+
+        int layer = reader.getInt16();
+        int alternateGroup = reader.getInt16();
+        int volume = reader.getInt16();
+
+        reader.skip(2); // reserved
+
+        int[] matrix = new int[9];
