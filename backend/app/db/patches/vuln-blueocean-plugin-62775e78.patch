+
+        JSONObject res = request()
+            .jwtToken(jwt)
+            .crumb(crumb)
+            .post(ORGANIZATIONS_URL + "?apiUrl=" + githubApiUrl + "&credentialId=" + GithubEnterpriseScm.ID)
