From 441aecb7d33014bd08672232c6c8bb69c2ceaba2 Mon Sep 17 00:00:00 2001
From: Steven Bird <stevenbird1@gmail.com>
Date: Fri, 9 Aug 2024 15:50:36 +0930
Subject: [PATCH] Update version to 3.8.2, add release notes

---
 ChangeLog    | 8 ++++++++
 nltk/VERSION | 2 +-
 web/conf.py  | 4 ++--
 web/news.rst | 7 +++++++
 4 files changed, 18 insertions(+), 3 deletions(-)

diff --git a/ChangeLog b/ChangeLog
index 1820cd7ae..9f80092e8 100644
--- a/ChangeLog
+++ b/ChangeLog
@@ -1,4 +1,12 @@
 
+Version 3.8.2 2024-08-09
+* Remove support for pickled models, resolves security vulnerability CVE-2024-39705
+* Many other minor fixes
+
+Thanks to the following contributors to 3.8.2:
+Tom Aarsen, Cat Lee Ball, Veralara Bernhard, Carlos Brandt, Konstantin Chernyshev, Michael Higgins,
+Eric Kafe, Vivek Kalyan, David Lukes, Rob Malouf, purificant, Alex Rudnick, Liling Tan, Akihiro Yamazaki.
+
 Version 3.8.1 2023-01-02
 
 * Resolve RCE vulnerability in localhost WordNet Browser (#3100)
diff --git a/nltk/VERSION b/nltk/VERSION
index f28071967..a08ffae0c 100644
--- a/nltk/VERSION
+++ b/nltk/VERSION
@@ -1 +1 @@
-3.8.1
+3.8.2
diff --git a/web/conf.py b/web/conf.py
index 9030b903f..b371f8bec 100644
--- a/web/conf.py
+++ b/web/conf.py
@@ -126,9 +126,9 @@ copyright = "2023, NLTK Project"
 # built documents.
 #
 # The short X.Y version.
-version = "3.8.1"
+version = "3.8.2"
 # The full version, including alpha/beta/rc tags.
-release = "3.8.1"
+release = "3.8.2"
 
 # The language for content autogenerated by Sphinx. Refer to documentation
 # for a list of supported languages.
diff --git a/web/news.rst b/web/news.rst
index 6bf0aeb0c..84da16c00 100644
--- a/web/news.rst
+++ b/web/news.rst
@@ -1,6 +1,13 @@
 Release Notes
 =============
 
+2024
+----
+
+NLTK 3.8.2 release: August 2024:
+- Remove support for pickled models, resolves security vulnerability CVE-2024-39705
+- Many other minor fixes
+
 2023
 ----
 
-- 
2.34.1

