         <Alternate_Terms>
            <Alternate_Term>
               <Term>Untrusted pointer offset</Term>
               <Description>This term is narrower than the concept of "out-of-range" offset, since the offset might be the result of a calculation or other error that does not depend on any externally-supplied values.</Description>
            </Alternate_Term>
         </Alternate_Terms>
