<Weakness xmlns="http://cwe.mitre.org/cwe-7" xmlns:xhtml="http://www.w3.org/1999/xhtml" ID="703" Name="Improper Check or Handling of Exceptional Conditions" Abstraction="Pillar" Structure="Simple" Status="Incomplete" Diagram="/data/images/CWE-703-Diagram.png">
