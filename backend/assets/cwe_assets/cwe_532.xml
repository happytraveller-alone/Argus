               <Reference>CVE-2018-1999036</Reference>
               <Description>SSH password for private key stored in build log</Description>
               <Link>https://www.cve.org/CVERecord?id=CVE-2018-1999036</Link>
            </Observed_Example>
         </Observed_Examples>
