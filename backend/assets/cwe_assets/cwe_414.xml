<Weakness xmlns="http://cwe.mitre.org/cwe-7" ID="414" Name="Missing Lock Check" Abstraction="Base" Structure="Simple" Status="Draft">
         <Description>A product does not check to see if a lock is present before performing sensitive operations on a resource.</Description>
         <Related_Weaknesses>
            <Related_Weakness Nature="ChildOf" CWE_ID="667" View_ID="1000" Ordinal="Primary" />
         </Related_Weaknesses>
         <Weakness_Ordinalities>
