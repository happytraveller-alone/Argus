<Weakness xmlns="http://cwe.mitre.org/cwe-7" ID="439" Name="Behavioral Change in New Version or Environment" Abstraction="Base" Structure="Simple" Status="Draft">
         <Description>A's behavior or functionality changes with a new version of A, or a new environment, which is not known (or manageable) by B.</Description>
         <Related_Weaknesses>
            <Related_Weakness Nature="ChildOf" CWE_ID="435" View_ID="1000" Ordinal="Primary" />
         </Related_Weaknesses>
