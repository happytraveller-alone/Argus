<Weakness xmlns="http://cwe.mitre.org/cwe-7" xmlns:xhtml="http://www.w3.org/1999/xhtml" ID="177" Name="Improper Handling of URL Encoding (Hex Encoding)" Abstraction="Variant" Structure="Simple" Status="Draft">
         <Description>The product does not properly handle when all or part of an input has been URL encoded.</Description>
         <Related_Weaknesses>
            <Related_Weakness Nature="ChildOf" CWE_ID="172" View_ID="1000" Ordinal="Primary" />
         </Related_Weaknesses>
         <Weakness_Ordinalities>
