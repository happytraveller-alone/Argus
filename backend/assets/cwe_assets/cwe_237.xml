<Weakness xmlns="http://cwe.mitre.org/cwe-7" xmlns:xhtml="http://www.w3.org/1999/xhtml" ID="237" Name="Improper Handling of Structural Elements" Abstraction="Base" Structure="Simple" Status="Incomplete">
