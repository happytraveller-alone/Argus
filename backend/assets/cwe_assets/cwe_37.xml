<?xml version='1.0' encoding='utf-8'?>
<Weakness xmlns="http://cwe.mitre.org/cwe-7" xmlns:xhtml="http://www.w3.org/1999/xhtml" ID="37" Name="Path Traversal: '/absolute/pathname/here'" Abstraction="Variant" Structure="Simple" Status="Draft">
         <Description>The product accepts input in the form of a slash absolute path ('/absolute/pathname/here') without appropriate validation, which can allow an attacker to traverse the file system to unintended locations or access arbitrary files.</Description>
         <Related_Weaknesses>
            <Related_Weakness Nature="ChildOf" CWE_ID="36" View_ID="1000" Ordinal="Primary" />
            <Related_Weakness Nature="ChildOf" CWE_ID="160" View_ID="1000" />
