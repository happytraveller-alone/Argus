<Weakness xmlns="http://cwe.mitre.org/cwe-7" xmlns:xhtml="http://www.w3.org/1999/xhtml" ID="172" Name="Encoding Error" Abstraction="Class" Structure="Simple" Status="Draft">
         <Description>The product does not properly encode or decode the data, resulting in unexpected values.</Description>
         <Related_Weaknesses>
            <Related_Weakness Nature="ChildOf" CWE_ID="707" View_ID="1000" Ordinal="Primary" />
