<Weakness xmlns="http://cwe.mitre.org/cwe-7" xmlns:xhtml="http://www.w3.org/1999/xhtml" ID="863" Name="Incorrect Authorization" Abstraction="Class" Structure="Simple" Status="Incomplete" Diagram="/data/images/CWE-863-Diagram.png">
         <Description>The product performs an authorization check when an actor attempts to access a resource or perform an action, but it does not correctly perform the check.</Description>
         <Related_Weaknesses>
            <Related_Weakness Nature="ChildOf" CWE_ID="285" View_ID="1000" Ordinal="Primary" />
			<Related_Weakness Nature="ChildOf" CWE_ID="284" View_ID="1340" Ordinal="Primary" />
         </Related_Weaknesses>
