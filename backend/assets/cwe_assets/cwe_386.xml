<Weakness xmlns="http://cwe.mitre.org/cwe-7" ID="386" Name="Symbolic Name not Mapping to Correct Object" Abstraction="Base" Structure="Simple" Status="Draft">
         <Description>A constant symbolic reference to an object is used, even though the reference can resolve to a different object over time.</Description>
         <Related_Weaknesses>
            <Related_Weakness Nature="ChildOf" CWE_ID="706" View_ID="1000" Ordinal="Primary" />
