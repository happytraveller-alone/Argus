<?xml version='1.0' encoding='utf-8'?>
<Weakness xmlns="http://cwe.mitre.org/cwe-7" xmlns:xhtml="http://www.w3.org/1999/xhtml" ID="835" Name="Loop with Unreachable Exit Condition ('Infinite Loop')" Abstraction="Base" Structure="Simple" Status="Incomplete" Diagram="/data/images/CWE-835-Diagram.png">
         <Description>The product contains an iteration or loop with an exit condition that cannot be reached, i.e., an infinite loop.</Description>
         <Related_Weaknesses>
            <Related_Weakness Nature="ChildOf" CWE_ID="834" View_ID="1000" Ordinal="Primary" />
            <Related_Weakness Nature="ChildOf" CWE_ID="834" View_ID="1003" Ordinal="Primary" />
         </Related_Weaknesses>
         <Weakness_Ordinalities>
            <Weakness_Ordinality>
               <Ordinality>Primary</Ordinality>
            </Weakness_Ordinality>
         </Weakness_Ordinalities>
         <Applicable_Platforms>
            <Language Class="Not Language-Specific" Prevalence="Undetermined" />
	    <Technology Class="Not Technology-Specific" Prevalence="Undetermined" />
         </Applicable_Platforms>
		 <Modes_Of_Introduction>
		   <Introduction>
			 <Phase>Implementation</Phase>
		   </Introduction>
