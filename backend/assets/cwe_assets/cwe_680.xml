<?xml version='1.0' encoding='utf-8'?>
<Weakness xmlns="http://cwe.mitre.org/cwe-7" xmlns:xhtml="http://www.w3.org/1999/xhtml" ID="680" Name="Integer Overflow to Buffer Overflow" Abstraction="Compound" Structure="Chain" Status="Draft">
         <Description>The product performs a calculation to determine how much memory to allocate, but an integer overflow can occur that causes less memory to be allocated than expected, leading to a buffer overflow.</Description>
         <Related_Weaknesses>
            <Related_Weakness Nature="StartsWith" CWE_ID="190" View_ID="709" Chain_ID="680" />
            <Related_Weakness Nature="ChildOf" CWE_ID="190" View_ID="1000" Ordinal="Primary" />
         </Related_Weaknesses>
         <Weakness_Ordinalities>
            <Weakness_Ordinality>
               <Ordinality>Primary</Ordinality>
            </Weakness_Ordinality>
         </Weakness_Ordinalities>
         <Applicable_Platforms>
