<Weakness xmlns="http://cwe.mitre.org/cwe-7" xmlns:xhtml="http://www.w3.org/1999/xhtml" ID="228" Name="Improper Handling of Syntactically Invalid Structure" Abstraction="Class" Structure="Simple" Status="Incomplete">
         <Description>The product does not handle or incorrectly handles input that is not syntactically well-formed with respect to the associated specification.</Description>
         <Related_Weaknesses>
            <Related_Weakness Nature="ChildOf" CWE_ID="703" View_ID="1000" />
            <Related_Weakness Nature="ChildOf" CWE_ID="707" View_ID="1000" Ordinal="Primary" />
         </Related_Weaknesses>
