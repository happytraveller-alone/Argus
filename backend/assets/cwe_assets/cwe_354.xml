                        <xhtml:div>
                           <xhtml:br />memset(msg, 0x0, MAX_MSG);<xhtml:br />clilen = sizeof(cli);<xhtml:br />if (inet_ntoa(cli.sin_addr)==...) n = recvfrom(sd, msg, MAX_MSG, 0, (struct sockaddr *) &amp; cli, &amp;clilen);</xhtml:div>
                     </xhtml:div>}</xhtml:div>
               </Example_Code>
               <Example_Code Nature="Bad" Language="Java">
                  <xhtml:div>while(true) {<xhtml:div style="margin-left:1em;">DatagramPacket packet = new DatagramPacket(data,data.length,IPAddress, port);<xhtml:br />socket.send(sendPacket);</xhtml:div>}</xhtml:div>
