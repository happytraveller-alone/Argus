            <Related_Weakness Nature="ChildOf" CWE_ID="345" View_ID="1000" Ordinal="Primary" />
            <Related_Weakness Nature="ChildOf" CWE_ID="345" View_ID="1003" Ordinal="Primary" />
            <Related_Weakness Nature="ChildOf" CWE_ID="754" View_ID="1000" />
