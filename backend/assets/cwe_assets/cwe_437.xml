               <Reason Type="Acceptable-Use" />
            </Reasons>
         </Mapping_Notes>
         <Notes>
            <Note Type="Relationship">This can be related to interaction errors, although in some cases, one of the endpoints is not performing correctly according to specification.</Note>
         </Notes>
