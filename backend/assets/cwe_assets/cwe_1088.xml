<?xml version='1.0' encoding='utf-8'?>
<Weakness xmlns="http://cwe.mitre.org/cwe-7" ID="1088" Name="Synchronous Access of Remote Resource without Timeout" Abstraction="Base" Structure="Simple" Status="Incomplete">
         <Description>The code has a synchronous call to a remote resource, but there is no timeout for the call, or the timeout is set to infinite.</Description>
         <Related_Weaknesses>
            <Related_Weakness Nature="ChildOf" CWE_ID="821" View_ID="1000" Ordinal="Primary" />
         </Related_Weaknesses>
         <Weakness_Ordinalities>
            <Weakness_Ordinality>
               <Ordinality>Indirect</Ordinality>
            </Weakness_Ordinality>
         </Weakness_Ordinalities>
         <Applicable_Platforms>
            <Language Class="Not Language-Specific" Prevalence="Undetermined" />
         </Applicable_Platforms>
         <Modes_Of_Introduction>
            <Introduction>
               <Phase>Architecture and Design</Phase>
            </Introduction>
         </Modes_Of_Introduction>
         <Common_Consequences>
            <Consequence>
               <Scope>Other</Scope>
               <Impact>Reduce Reliability</Impact>
	       <Note>This issue can prevent the product from running reliably, since an outage for the remote resource can cause the product to hang.  If the relevant code is reachable by an attacker, then this reliability problem might introduce a vulnerability.</Note>
            </Consequence>
         </Common_Consequences>
         <Observed_Examples>
            <Observed_Example>
               <Reference>CVE-2024-8062</Reference>
               <Description>API endpoint performs a HEAD request without a timeout, allowing attackers to cause the server to hang</Description>
               <Link>https://www.cve.org/CVERecord?id=CVE-2024-8062</Link>
            </Observed_Example>
            <Observed_Example>
               <Reference>CVE-2024-8061</Reference>
               <Description>development product for AI can make requests to external servers without timeouts and does not respond to other requests while waiting, allowing DoS</Description>
               <Link>https://www.cve.org/CVERecord?id=CVE-2024-8061</Link>
            </Observed_Example>
         </Observed_Examples>
