<?xml version="1.0" encoding="UTF-8"?>
<ruleset name="AssignmentInOperand Ruleset"
    xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.sourceforge.io/ruleset_2_0_0.xsd">

    <description>Independent ruleset for AssignmentInOperand</description>

    <rule xmlns="http://pmd.sourceforge.net/ruleset/2.0.0" name="AssignmentInOperand" language="java" since="1.03" message="Avoid assignment to {0} in operand" class="net.sourceforge.pmd.lang.java.rule.errorprone.AssignmentInOperandRule" externalInfoUrl="${pmd.website.baseurl}/pmd_rules_java_errorprone.html#assignmentinoperand">
            <description>
    Avoid assignments in operands; this can make code more complicated and harder to read.
            </description>
            <priority>3</priority>
            <example>

    public void bar() {
        int x = 2;
        if ((x = getX()) == 3) {
          System.out.println("3!");
        }
    }

            </example>
        </rule>

        

</ruleset>
