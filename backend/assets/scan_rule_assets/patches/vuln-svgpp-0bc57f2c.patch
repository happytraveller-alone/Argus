From 0bc57f2cc6d9d86a0fa1ce73e508c2b5994b4b91 Mon Sep 17 00:00:00 2001
From: svgpp <olegmax@gmail.com>
Date: Fri, 30 Sep 2022 19:00:30 +0300
Subject: [PATCH] Fix handling of XML without root

---
 src/demo/render/svgpp_render.cpp | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/src/demo/render/svgpp_render.cpp b/src/demo/render/svgpp_render.cpp
index 1a4b40c..35be6e0 100644
--- a/src/demo/render/svgpp_render.cpp
+++ b/src/demo/render/svgpp_render.cpp
@@ -1656,7 +1656,10 @@ void renderDocument(XMLDocument & xmlDocument, ImageBuffer & buffer)
 {
   Document document(xmlDocument);
   Canvas canvas(document, buffer);
-  document_traversal_main::load_document(xmlDocument.getRoot(), canvas);
+  if (XMLElement root = xmlDocument.getRoot())
+    document_traversal_main::load_document(root, canvas);
+  else
+    throw std::runtime_error("No root XML element");
 }
 
 int main(int argc, char * argv[])
