From 98456628a24bba25d336860d38a45b5a4e3895da Mon Sep 17 00:00:00 2001
From: "adrian@moodle.com" <abgreeve@gmail.com>
Date: Fri, 2 Dec 2011 16:33:25 +0800
Subject: [PATCH] MDL-28948 - lib - removed the hard coded key for the
 rc4encryt function.

---
 lib/moodlelib.php | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/lib/moodlelib.php b/lib/moodlelib.php
index d6bba110a09..8ec7bc93ff2 100644
--- a/lib/moodlelib.php
+++ b/lib/moodlelib.php
@@ -7213,7 +7213,7 @@ class emoticon_manager {
  * @return string The now encrypted data
  */
 function rc4encrypt($data) {
-    $password = 'nfgjeingjk';
+    $password = get_site_identifier();
     return endecrypt($password, $data, '');
 }
 
@@ -7226,7 +7226,7 @@ function rc4encrypt($data) {
  * @return string The now decrypted data
  */
 function rc4decrypt($data) {
-    $password = 'nfgjeingjk';
+    $password = get_site_identifier();
     return endecrypt($password, $data, 'de');
 }
 
-- 
2.34.1

