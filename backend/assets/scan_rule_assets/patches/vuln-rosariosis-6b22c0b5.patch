 <francoisjacquet@users.noreply.github.com>
Date: Sat, 4 Jun 2022 13:44:21 +0200
Subject: [PATCH] Fix stored XSS security issue: remove inline JS from URL in
 PreparePHP_SELF.fnc.php

---
 functions/PreparePHP_SELF.fnc.php | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/functions/PreparePHP_SELF.fnc.php b/functions/PreparePHP_SELF.fnc.php
index 80da4699..f7dfe677 100644
--- a/functions/PreparePHP_SELF.fnc.php
+++ b/functions/PreparePHP_SELF.fnc.php
@@ -200,7 +200,7 @@ function URLEscape( $string )
 
 	foreach ( $remove as $remove_string )
 	{
-		while ( strpos( $string, $remove_string ) !== false )
+		while ( stripos( $string, $remove_string ) !== false )
 		{
 			$string = str_ireplace( $remove, '', $string );
 		}
-- 
