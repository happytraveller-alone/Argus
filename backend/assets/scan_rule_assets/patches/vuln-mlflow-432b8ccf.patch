From 432b8ccf27fd3a76df4ba79bb1bec62118a85625 Mon Sep 17 00:00:00 2001
From: Harutaka Kawamura <hkawamura0130@gmail.com>
Date: Fri, 8 Dec 2023 01:09:41 +0900
Subject: [PATCH] Use `SandboxedEnvironment` when rendering cards (#10640)

Signed-off-by: harupy <17039389+harupy@users.noreply.github.com>
---
 mlflow/recipes/cards/__init__.py | 5 +++--
 1 file changed, 3 insertions(+), 2 deletions(-)

diff --git a/mlflow/recipes/cards/__init__.py b/mlflow/recipes/cards/__init__.py
index 24361b8acbf6c..dafdaa89f23ec 100644
--- a/mlflow/recipes/cards/__init__.py
+++ b/mlflow/recipes/cards/__init__.py
@@ -120,9 +120,10 @@ def to_html(self) -> str:
 
         :return: a HTML string
         """
-        import jinja2
+        from jinja2 import BaseLoader
+        from jinja2.sandbox import SandboxedEnvironment
 
-        j2_env = jinja2.Environment(loader=jinja2.BaseLoader()).from_string(self.template)
+        j2_env = SandboxedEnvironment(loader=BaseLoader()).from_string(self.template)
         return j2_env.render({**self._context})
 
 
