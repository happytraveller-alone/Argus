 			return STF_INTERNAL_ERROR;
 		}
-		d = pbs_out_address(&ts_pbs2, &ts->net.end, "IP end");
+		d = pbs_out_address(&ts_range_pbs, &ts->net.end, "IP end");
 		if (d != NULL) {
