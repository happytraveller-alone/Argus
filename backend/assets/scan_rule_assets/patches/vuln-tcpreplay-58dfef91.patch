From 58dfef91fa206f29e52fc5f7efeeb334eeaf37c6 Mon Sep 17 00:00:00 2001
From: Fred Klassen <fklassen@appneta.com>
Date: Sat, 20 Oct 2018 04:16:08 -0700
Subject: [PATCH] Bug #488 heap overflow csum replace4 (#496)

* Bug #488 check for available buffer space before any packet edits

* Bug #488 update CHANGELOG
---
 docs/CHANGELOG                                |  1 +
 src/bridge.c                                  |  3 +-
 src/common/flows.c                            |  8 +-
 src/common/get.c                              | 14 +--
 src/common/get.h                              |  2 +-
 src/tcpedit/edit_packet.c                     | 96 +++++++++++++------
 src/tcpedit/edit_packet.h                     | 10 +-
 src/tcpedit/fuzzing.c                         |  6 +-
 src/tcpedit/plugins/dlt_en10mb/en10mb.c       | 28 +++---
 src/tcpedit/plugins/dlt_hdlc/hdlc.c           | 10 +-
 src/tcpedit/plugins/dlt_ieee80211/ieee80211.c | 11 +--
 .../plugins/dlt_jnpr_ether/jnpr_ether.c       | 16 ++--
 src/tcpedit/plugins/dlt_linuxsll/linuxsll.c   |  8 +-
 src/tcpedit/plugins/dlt_plugins.c             | 29 +++++-
 src/tcpedit/plugins/dlt_pppserial/pppserial.c |  8 +-
 src/tcpedit/plugins/dlt_radiotap/radiotap.c   | 13 ++-
 src/tcpedit/plugins/dlt_user/user.c           |  5 +-
 src/tcpedit/portmap.c                         |  4 +-
 src/tcpedit/tcpedit.c                         | 91 +++++++++---------
 src/tcpedit/tcpedit.h                         |  1 -
 20 files changed, 213 insertions(+), 151 deletions(-)

diff --git a/docs/CHANGELOG b/docs/CHANGELOG
index 01510206..197afd19 100644
--- a/docs/CHANGELOG
+++ b/docs/CHANGELOG
@@ -1,5 +1,6 @@
 10/18/2018 Version 4.3.0 beta2
     - fix issues identifed by Codacy (#493)
+    - CVE-2018-18407 heap-buffer-overflow csum_replace4 (#488)
     - CVE-2018-17974 heap-buffer-overflow dlt_en10mb_encode (#486)
     - CVE-2018-17582 heap-buffer-overflow in get_next_packet (#484)
     - CVE-2018-13112 heap-buffer-overflow in get_l2len (#477 dup #408)
diff --git a/src/bridge.c b/src/bridge.c
