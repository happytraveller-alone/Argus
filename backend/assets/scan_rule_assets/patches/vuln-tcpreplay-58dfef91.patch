         return;
 
     /* if this is a fragment, don't attempt to checksum the Layer4 header */
@@ -252,17 +271,34 @@ static void ipv4_addr_csum_replace(ipv4_hdr_t *ip_hdr, uint32_t old_ip, uint32_t
