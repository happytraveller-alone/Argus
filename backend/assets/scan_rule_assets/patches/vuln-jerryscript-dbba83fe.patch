Subject: [PATCH] Fix typedarray validation in Atomics read_modify_write
 (#4879)

This patch fixes #4875.

JerryScript-DCO-1.0-Signed-off-by: Robert Fancsik robert.fancsik@h-lab.eu
---
 .../ecma/operations/ecma-atomics-object.c     |  4 ++--
 .../es.next/regression-test-issue-4875.js     | 20 +++++++++++++++++++
 tests/test262-esnext-excludelist.xml          | 15 +-------------
 3 files changed, 23 insertions(+), 16 deletions(-)
 create mode 100644 tests/jerry/es.next/regression-test-issue-4875.js

diff --git a/jerry-core/ecma/operations/ecma-atomics-object.c b/jerry-core/ecma/operations/ecma-atomics-object.c
index 25a7349c..6e2cfd0e 100644
--- a/jerry-core/ecma/operations/ecma-atomics-object.c
+++ b/jerry-core/ecma/operations/ecma-atomics-object.c
@@ -51,9 +51,9 @@ ecma_validate_shared_integer_typedarray (ecma_value_t typedarray, /**< typedArra
                                          bool waitable) /**< waitable argument */
 {
   /* 2. */
-  if (!ecma_is_value_object (typedarray))
+  if (!ecma_is_typedarray (typedarray))
   {
-    return ecma_raise_type_error (ECMA_ERR_ARGUMENT_THIS_NOT_OBJECT);
+    return ecma_raise_type_error (ECMA_ERR_ARGUMENT_THIS_NOT_TYPED_ARRAY);
   }
 
   /* 3-4. */
diff --git a/tests/jerry/es.next/regression-test-issue-4875.js b/tests/jerry/es.next/regression-test-issue-4875.js
new file mode 100644
index 00000000..e7bdfeef
--- /dev/null
+++ b/tests/jerry/es.next/regression-test-issue-4875.js
@@ -0,0 +1,20 @@
