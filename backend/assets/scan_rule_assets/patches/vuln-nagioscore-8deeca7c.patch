+html/js/histogram.js
+html/js/map.js
+html/js/trends.js
diff --git a/Changelog b/Changelog
index 0a7abcdb..15468d9d 100644
--- a/Changelog
+++ b/Changelog
@@ -2,6 +2,11 @@
 Nagios Core 4 Change Log
 ########################
 
+4.4.6 - 2020-??-??
+------------------
+FIXES
+* Fixed postauth vulnerabilities in histogram.js, map.js, trends.js (CVE-2020-1408) (Thanks UraSec Team) (Sebastian Wolf)
+
 4.4.5 - 2019-08-20
 ------------------
 FIXES
diff --git a/configure b/configure
index 56d14a31..6407a086 100755
--- a/configure
+++ b/configure
@@ -8866,6 +8866,9 @@ fi
 
 perl subst include/locations.h
 perl subst html/config.inc.php
+perl subst html/js/histogram.js
+perl subst html/js/map.js
+perl subst html/js/trends.js
 
 
 echo ""
diff --git a/configure.ac b/configure.ac
index 0bfab673..70de5e7a 100644
--- a/configure.ac
+++ b/configure.ac
@@ -923,6 +923,9 @@ AC_OUTPUT([
 
 perl subst include/locations.h
 perl subst html/config.inc.php
+perl subst html/js/histogram.js
+perl subst html/js/map.js
+perl subst html/js/trends.js
 dnl perl subst daemon-service
 
 
