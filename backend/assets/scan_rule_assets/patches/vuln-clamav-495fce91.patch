From 495fce917445063d519f14b0009cee025f817bc3 Mon Sep 17 00:00:00 2001
From: Mickey Sola <msola@sourcefire.com>
Date: Fri, 16 Feb 2018 14:24:07 -0500
Subject: [PATCH] 0.100.x - removing checklen constraint based on key string
 size when parsing pdf string objects

---
 libclamav/pdfng.c | 7 +------
 1 file changed, 1 insertion(+), 6 deletions(-)

diff --git a/libclamav/pdfng.c b/libclamav/pdfng.c
index ec0a0675d..57b022fbc 100644
--- a/libclamav/pdfng.c
+++ b/libclamav/pdfng.c
@@ -590,12 +590,7 @@ char *pdf_parse_string(struct pdf_struct *pdf, struct pdf_obj *obj, const char *
 
     /* Make a best effort to find the end of the string and determine if UTF-* */
     p2 = ++p1;
-    if (!str) {
-        checklen = cli_strnlen(p1, objsize - 1) + 1;
-    }
-    else {
-        checklen = cli_strnlen(p1, checklen) + 1;
-    }
+    checklen = cli_strnlen(p1, objsize - 1) + 1;
 
     while (p2 < objstart + checklen) {
         int shouldbreak=0;
-- 
2.34.1

