   int running_sum = 0;
   int num_digits  = 0;
 
@@ -129,8 +136,8 @@ struct ChunkedHandler {
   //@}
   ChunkedHandler();
 
-  void init(IOBufferReader *buffer_in, HttpTunnelProducer *p);
