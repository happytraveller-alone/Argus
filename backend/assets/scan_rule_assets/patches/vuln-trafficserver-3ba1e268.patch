+
+    proxy-request:
+      content:
+        transfer: plain
+        encoding: uri
+        # Note: same as server-response, but the trailer is dropped.
+        data: 3%0D%0Aabc%0D%0A0%0D%0A%0D%0A
+        verify: { as: equal }
