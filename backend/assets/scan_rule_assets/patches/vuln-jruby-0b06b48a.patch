 .../stdlib/rubygems/package/tar_writer.rb     |  2 +
 lib/ruby/stdlib/rubygems/server.rb            | 14 ++++++-
 lib/ruby/stdlib/rubygems/specification.rb     | 15 ++++++--
 7 files changed, 75 insertions(+), 20 deletions(-)

