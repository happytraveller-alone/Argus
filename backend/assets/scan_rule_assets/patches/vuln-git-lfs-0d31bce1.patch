 	cp -R $^ $$dir && mv $$dir/git-lfs-darwin-$* $$dir/git-lfs && \
 	zip -j $@ $$dir/* && \
-	zip -u $@ man/* && \
+	zip -ur $@ man && \
 	$(RM) -r $$dir
 
