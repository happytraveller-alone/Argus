From bac703c534d05d4502580fbe32447d5c777869bf Mon Sep 17 00:00:00 2001
From: Paul Holden <paulh@moodle.com>
Date: Wed, 11 Oct 2023 10:41:47 +0100
Subject: [PATCH] MDL-54749 tool_langimport: require sesskey to update lang
 packs.

---
 admin/tool/langimport/index.php                     | 2 +-
 admin/tool/langimport/templates/langimport.mustache | 1 +
 2 files changed, 2 insertions(+), 1 deletion(-)

diff --git a/admin/tool/langimport/index.php b/admin/tool/langimport/index.php
index 4940db3be46..39938e89cb4 100644
--- a/admin/tool/langimport/index.php
+++ b/admin/tool/langimport/index.php
@@ -114,7 +114,7 @@ if ($mode == DELETION_OF_SELECTED_LANG and (!empty($uninstalllang) or !empty($co
     }
 }
 
-if ($mode == UPDATE_ALL_LANG) {
+if ($mode == UPDATE_ALL_LANG && confirm_sesskey()) {
     core_php_time_limit::raise();
     $controller->update_all_installed_languages();
 }
diff --git a/admin/tool/langimport/templates/langimport.mustache b/admin/tool/langimport/templates/langimport.mustache
index 5aff9a6b2ed..957f0730133 100644
--- a/admin/tool/langimport/templates/langimport.mustache
+++ b/admin/tool/langimport/templates/langimport.mustache
@@ -87,6 +87,7 @@
                 <div>
                     <form id="updateform" action="{{updateurl}}" method="post">
                         <fieldset>
+                            <input type="hidden" name="sesskey" value="{{sesskey}}">
                             <input type="submit" value="{{#str}}updatelangs, tool_langimport{{/str}}" class="btn btn-secondary">
                             {{#hasmanyinstalledlanguages}}
                                 <p class="mt-2 small">{{#str}} updatelangsnote, tool_langimport, {"taskname": {{#quote}}{{updatelangstaskname}}{{/quote}} }{{/str}}</p>
-- 
2.34.1

