From 79d1e9207c5c359ca779b92f0a290e18c5e2387b Mon Sep 17 00:00:00 2001
From: Devin Nusbaum <d.w.nusbaum@gmail.com>
Date: Thu, 17 Sep 2020 15:28:34 -0400
Subject: [PATCH] [SECURITY-2020]

---
 pom.xml                                       |  2 +-
 .../groovy/SandboxInterceptorTest.java        | 22 +++++++++++++++++++
 2 files changed, 23 insertions(+), 1 deletion(-)

diff --git a/pom.xml b/pom.xml
index 40fba66e0..8a4efdade 100644
--- a/pom.xml
+++ b/pom.xml
@@ -63,7 +63,7 @@
     <dependency>
       <groupId>org.kohsuke</groupId>
       <artifactId>groovy-sandbox</artifactId>
-      <version>1.26</version>
+      <version>1.27</version>
       <exclusions>
         <exclusion>
           <groupId>org.codehaus.groovy</groupId>
diff --git a/src/test/java/org/jenkinsci/plugins/scriptsecurity/sandbox/groovy/SandboxInterceptorTest.java b/src/test/java/org/jenkinsci/plugins/scriptsecurity/sandbox/groovy/SandboxInterceptorTest.java
index f2178b9da..7ded4e115 100644
--- a/src/test/java/org/jenkinsci/plugins/scriptsecurity/sandbox/groovy/SandboxInterceptorTest.java
+++ b/src/test/java/org/jenkinsci/plugins/scriptsecurity/sandbox/groovy/SandboxInterceptorTest.java
@@ -1397,6 +1397,28 @@ public void blockIllegalAnnotationsInAnnotations() throws Exception {
                 "new Test().hello\n");
     }
 
+    @Issue("SECURITY-2020")
+    @Test public void unsafeReturnValue() throws Throwable {
+        try {
+            Object result = evaluate(new GenericWhitelist(),
+                    "class Test {\n" +
+                    "  @Override public String toString() {\n" +
+                    "    jenkins.model.Jenkins.get().setSystemMessage('Hello, world!')\n" +
+                    "    'test'\n" +
+                    "  }\n" +
+                    "}\n" + 
+                    "new Test()");
+            // Test.equals and Test.getClass are inherited and not sandbox-transformed, so they can be called outside of the sandbox.
+            assertFalse(result.equals(new Object()));
+            assertThat(result.getClass().getSimpleName(), equalTo("Test"));
+            // Test.toString is defined in the sandbox, so it cannot be called outside of the sandbox.
+            result.toString();
+            fail("Test.toString should throw a SecurityException");
+        } catch (SecurityException e) {
+            assertThat(e.getMessage(), equalTo("Rejecting unsandboxed static method call: jenkins.model.Jenkins.get()"));
+        }
+    }
+
     /**
      * Checks that the annotation is blocked from being used in the provided script whether it is imported or used via
      * fully-qualified class name.
