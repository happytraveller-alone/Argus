From e089b2e2c1d38c5696c7dfd741e21f8f3ef22b14 Mon Sep 17 00:00:00 2001
From: Sebastian Rasmussen <sebras@gmail.com>
Date: Tue, 11 Apr 2017 11:04:12 +0800
Subject: [PATCH] jstest: Stop printing bogus script lines.

---
 platform/x11/jstest_main.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/platform/x11/jstest_main.c b/platform/x11/jstest_main.c
index f158d9628..36b321555 100644
--- a/platform/x11/jstest_main.c
+++ b/platform/x11/jstest_main.c
@@ -402,7 +402,7 @@ main(int argc, char *argv[])
 				}
 				else
 				{
-					fprintf(stderr, "Unmatched: %s\n", line);
+					fprintf(stderr, "Ignoring line without script statement.\n");
 				}
 			}
 			while (!feof(script));
