{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://argus.local/schemas/agentflow/runner_input.schema.json",
  "title": "Argus AgentFlow P1 Runner Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "task_id",
    "project_id",
    "project_root",
    "target",
    "topology_version",
    "audit_scope",
    "output_dir",
    "llm",
    "resource_budget"
  ],
  "properties": {
    "contract_version": { "const": "argus-agentflow-p1/v1" },
    "task_id": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string", "minLength": 1 },
    "project_root": { "type": "string", "minLength": 1 },
    "target": { "enum": ["local", "container"] },
    "topology_version": { "const": "p1-fixed-dag-v1" },
    "audit_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_files", "exclude_patterns", "target_vulnerabilities", "verification_level"],
      "properties": {
        "target_files": { "type": "array", "items": { "type": "string" } },
        "exclude_patterns": { "type": "array", "items": { "type": "string" } },
        "target_vulnerabilities": { "type": "array", "items": { "type": "string" } },
        "verification_level": { "enum": ["basic", "standard", "strict"] },
        "prompt_skill": { "type": ["string", "null"] },
        "extra": { "type": "object" }
      },
      "not": { "$ref": "#/$defs/forbiddenStaticInputObject" }
    },
    "output_dir": { "type": "string", "minLength": 1 },
    "llm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "model"],
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "base_url": { "type": ["string", "null"] },
        "api_key_ref": { "type": ["string", "null"] }
      }
    },
    "resource_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_cpu_cores", "max_memory_mb", "max_duration_seconds", "max_concurrency"],
      "properties": {
        "max_cpu_cores": { "type": "number", "exclusiveMinimum": 0 },
        "max_memory_mb": { "type": "integer", "minimum": 1 },
        "max_duration_seconds": { "type": "integer", "minimum": 1 },
        "max_concurrency": { "type": "integer", "minimum": 1 }
      }
    },
    "metadata": { "type": "object" }
  },
  "$defs": {
    "forbiddenStaticInputObject": {
      "type": "object",
      "anyOf": [
        { "required": ["static_task_id"] },
        { "required": ["opengrep_task_id"] },
        { "required": ["candidate_finding_ids"] },
        { "required": ["static_findings"] },
        { "required": ["bootstrap_task_id"] },
        { "required": ["bootstrap_candidate_count"] },
        { "required": ["candidate_findings"] }
      ]
    }
  }
}
