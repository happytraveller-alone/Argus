{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentResult",
  "type": "object",
  "required": ["status", "summary", "structured_outputs", "diagnostics"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["success", "failure", "partial"]
    },
    "summary": {
      "type": "string"
    },
    "structured_outputs": {
      "type": "object"
    },
    "diagnostics": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
