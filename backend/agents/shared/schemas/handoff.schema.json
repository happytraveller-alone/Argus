{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HandoffRequest",
  "type": "object",
  "required": ["role", "task_id", "project_id", "correlation_id", "payload"],
  "properties": {
    "role": {
      "type": "string",
      "enum": ["recon", "analysis", "verification", "report"]
    },
    "task_id": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "correlation_id": {
      "type": "string"
    },
    "payload": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
