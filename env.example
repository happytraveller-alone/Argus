# =============================================
# Argus root environment template
# =============================================
# Bootstrap copies this file to .env on first run and auto-generates SECRET_KEY.
# Fill the LLM values in .env, then run:
#   ./scripts/validate-llm-config.sh --env-file ./.env
#   ./argus-bootstrap.sh

# Local Docker socket mounted into backend for scanner runner orchestration.
# Linux default: /var/run/docker.sock
# This workspace may use: /run/docker-local.sock
DOCKER_SOCKET_PATH=/var/run/docker.sock
# Podman users can point DOCKER_SOCKET_PATH at the Podman socket instead:
# rootful: /run/podman/podman.sock
# rootless: /run/user/<uid>/podman/podman.sock
# PODMAN_SOCKET_PATH=/run/podman/podman.sock
CONTAINER_CLI=docker

# Host ports.
Argus_FRONTEND_PORT=13000
Argus_BACKEND_PORT=18000
Argus_DB_PORT=5432
FRONTEND_PUBLIC_URL=http://localhost:13000
BACKEND_PUBLIC_URL=http://localhost:18000
VITE_API_BASE_URL=/api/v1
VITE_API_TARGET=http://host.docker.internal:18000
VITE_HMR_HOST=localhost
VITE_HMR_PORT=13000
VITE_APP_ID=Argus
VITE_OUTPUT_LANGUAGE=zh-CN

# Database.
POSTGRES_DB=Argus

# Security. Bootstrap replaces this placeholder automatically.
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# LLM config imported into backend system-config during bootstrap.
LLM_PROVIDER=openai_compatible
LLM_API_KEY=sk-your-api-key
LLM_MODEL=
LLM_BASE_URL=
LLM_TIMEOUT=150
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# Agent audit runtime.
AGENT_ENABLED=true
AGENT_MAX_ITERATIONS=5
AGENT_TIMEOUT=1800
ENABLE_PARALLEL_ANALYSIS=true
ENABLE_PARALLEL_VERIFICATION=true
ANALYSIS_MAX_WORKERS=5
VERIFICATION_MAX_WORKERS=3

# Scan resource controls. 0 means auto.
MAX_ANALYZE_FILES=0
MAX_FILE_SIZE_BYTES=204800
LLM_CONCURRENCY=3
LLM_GAP_MS=2000
VITE_MAX_ANALYZE_FILES=0
VITE_LLM_CONCURRENCY=2
VITE_LLM_GAP_MS=500
OPENGREP_SCAN_JOBS=0
OPENGREP_RUNNER_CPU_LIMIT=0
OPENGREP_SCAN_MAX_MEMORY_MB=2048
OPENGREP_RUNNER_MEMORY_LIMIT_MB=2048
# Source-directory size limit (MiB) above which the a3s-box opengrep runner
# skips localization (the copy of workspace source into the box-local tmpfs
# /tmp/argus-a3s-opengrep-{box_name}) and runs opengrep directly against the
# virtiofs-mounted host workspace. Workspaces below the limit still localize
# (the perf optimisation from commit 22fbb587). Set to 0 to fully disable
# localization. Default: 50 MiB — keeps small projects fast while preventing
# FFMPEG-scale projects from OOM-killing the 2 GiB box on tmpfs.
ARGUS_A3S_LOCALIZE_LIMIT_MB=50
SCANNER_OPENGREP_IMAGE=argus/opengrep-runner-local:latest
# Optional A3S Box OpenGrep image override. Defaults to SCANNER_OPENGREP_IMAGE
# in compose/backend config; use only when the MicroVM runner needs a different
# OCI image tag. A3S Box requires a lowercase OCI repository name.
SCANNER_OPENGREP_A3S_BOX_IMAGE=
# Host group ID allowed to access /dev/kvm and /dev/vhost-vsock from backend.
# Default 109 matches Ubuntu/WSL kvm; override with `getent group kvm | cut -d: -f3`
# when your host uses a different kvm group id.
ARGUS_KVM_GROUP_ID=109
# CodeQL analyze --ram / --threads pass-through (backend/src/scan/codeql_cubesandbox.rs).
# Backend default is 6144 MB, but the standard CubeSandbox host caps memory at 2 GiB
# (matches scripts/cubesandbox-quickstart.sh:953 smoke-test config). Without this
# override the query evaluator OOMs on startup even on tiny sources.
CODEQL_RAM_MB=2048
CODEQL_THREADS=1
# CodeQL C/C++ compile-mode exploration cap. Argus probes alternate build commands
# until one CodeQL accepts; this caps the number of attempts before the task fails
# with "compile exploration exhausted".
CODEQL_MAX_BUILD_INFERENCE_ROUNDS=8

# CubeSandbox runtime seeds. Saved system_config.otherConfig.cubeSandbox is runtime truth.
CUBESANDBOX_ENABLED=true
CUBESANDBOX_API_BASE_URL=http://host.docker.internal:23000
CUBESANDBOX_DATA_PLANE_BASE_URL=https://host.docker.internal:21443
# Optional override. Leave empty so the backend auto-provisions the CodeQL
# C/C++ template (镜像构建 + cubemastercli tpl create-from-image + 注册)
# on the first scan or via the CodeqlExplorationPanel rebuild button.
# Set explicitly only when an externally-built template should be forced.
CUBESANDBOX_TEMPLATE_ID=
# Optional OpenGrep CubeSandbox template override. Leave empty so tasks that
# select opengrep_sandbox=oci_cubesandbox resolve the current dedicated
# internal kind (opengrep_dedicated): DB ready row first, then backend lazy
# provisioning. If set, point it only at a template built from the dedicated
# oci/cubesandbox/opengrep.Dockerfile image, not a historical/shared template.
CUBESANDBOX_OPENGREP_TEMPLATE_ID=
CUBESANDBOX_HELPER_PATH=/app/scripts/cubesandbox-quickstart.sh
CUBESANDBOX_WORK_DIR=.cubesandbox
CUBESANDBOX_AUTO_START=true
CUBESANDBOX_AUTO_INSTALL=true
# Host-side bootstrap automation (driven by argus-bootstrap.sh on the WSL2 host).
# Independent of CUBESANDBOX_AUTO_START / CUBESANDBOX_AUTO_INSTALL above, which
# govern the backend's in-container lazy recovery. Defaults to true so a fresh
# clone runs end-to-end on first ./argus-bootstrap.sh invocation.
CUBESANDBOX_BOOTSTRAP_AUTO=true
# Pre-provision the CodeQL C/C++ template during bootstrap. Set to false if you
# want to keep the template lazy and let the backend provision on first scan.
CUBESANDBOX_BOOTSTRAP_PROVISION_TEMPLATE=true
# Reuse an already-built CodeQL C/C++ image during template reset/provision.
# Set false only when Dockerfile/build args changed and a fresh image is required.
CUBE_CODEQL_CPP_REUSE_EXISTING_IMAGE=true
# CodeQL C/C++ template writable-layer-size. scripts/cubesandbox-quickstart.sh:33
# now defaults to 16Gi (raised from legacy 4Gi on 2026-05-04 to fit the CodeQL
# DB + trap caches at runtime). Pinned here so an externally-supplied env or a
# stale shell session does not silently fall back to 4Gi.
# See oci/cubesandbox/PATCHES.md (P1) and .omc/specs/deep-dive-sandbox-storage-insufficient.md.
CUBE_CODEQL_CPP_WRITABLE_LAYER_SIZE=16Gi
CUBESANDBOX_HELPER_TIMEOUT_SECONDS=600
CUBESANDBOX_EXECUTION_TIMEOUT_SECONDS=120
CUBESANDBOX_SANDBOX_CLEANUP_TIMEOUT_SECONDS=30
CUBESANDBOX_STDOUT_LIMIT_BYTES=65536
CUBESANDBOX_STDERR_LIMIT_BYTES=65536

# Storage and seed archive probes.
ZIP_STORAGE_PATH=./uploads/zip_files
SEED_ARCHIVE_PROBE_ATTEMPTS=2
SEED_ARCHIVE_PROBE_TIMEOUT_SECONDS=5
SEED_ARCHIVE_DOWNLOAD_TIMEOUT_SECONDS=180

# Optional repository tokens.
GITHUB_TOKEN=
GITLAB_TOKEN=
GITEA_TOKEN=

# Optional embedding/vector settings.
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
VECTOR_DB_TYPE=chroma
CHROMA_PERSIST_DIRECTORY=./data/chroma

# Optional image/build mirrors.
DOCKERHUB_LIBRARY_MIRROR=m.daocloud.io/docker.io/library
BACKEND_APT_MIRROR_PRIMARY=mirrors.aliyun.com
BACKEND_APT_SECURITY_PRIMARY=mirrors.aliyun.com
BACKEND_APT_MIRROR_FALLBACK=deb.debian.org
BACKEND_APT_SECURITY_FALLBACK=security.debian.org
BACKEND_PYPI_INDEX_CANDIDATES=https://mirrors.aliyun.com/pypi/simple/,https://pypi.tuna.tsinghua.edu.cn/simple,https://pypi.org/simple

# Git mirror defaults.
GIT_MIRROR_ENABLED=true
GIT_MIRROR_PREFIX=https://gh-proxy.org
GIT_MIRROR_PREFIXES=https://gh-proxy.org,https://v6.gh-proxy.org
GIT_MIRROR_HOSTS=github.com
GIT_MIRROR_ALLOW_AUTH_URL=false
GIT_MIRROR_FALLBACK_TO_ORIGIN=false

# MCP runtime defaults.
MCP_ENABLED=true
MCP_PREFER=true
MCP_STRICT_MODE=true
MCP_TIMEOUT_SECONDS=30
MCP_REQUIRE_ALL_READY_ON_STARTUP=true
