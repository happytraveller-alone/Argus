        "terser": "^5.46.2",
        "tsx": "^4.21.0",
        "typescript": "~6.0.3",
        "vite": "^8.0.10",
        "vite-plugin-javascript-obfuscator": "^3.1.0",
        "vite-plugin-svgr": "^5.2.0"
    },
    "overrides": {
        "react-helmet-async": {
            "react": "^16.8.0 || ^17 || ^18 || ^19"
