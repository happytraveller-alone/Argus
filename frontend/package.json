        "sonner": "^2.0.7",
        "streamdown": "^2.5.0",
        "tailwind-merge": "^3.5.0",
        "tailwindcss-animate": "^1.0.7",
        "three": "^0.184.0",
        "vanta": "^0.5.24",
        "vaul": "^1.1.2",
        "video-react": "^0.16.0",
        "zod": "^4.4.3"
