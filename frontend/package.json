{
    "name": "argus",
    "version": "0.0.1",
    "type": "module",
    "packageManager": "pnpm@11.0.8",
    "engines": {
        "node": ">=20.6.0",
        "pnpm": ">=11.0.8"
    },
    "scripts": {
        "dev": "vite",
        "build": "node scripts/clean.mjs && vite build",
        "preview": "vite preview --strictPort --port 5173",
        "lint": "tsgo -p tsconfig.check.json && biome lint --only=correctness/noUndeclaredDependencies src tests scripts",
        "lint:fix": "biome check --apply .",
        "format": "biome format --write .",
        "type-check": "tsc --noEmit",
        "type-check:docker": "bash scripts/run-in-dev-container.sh pnpm type-check",
        "test:node": "node scripts/run-node-tests.mjs",
        "test:docker": "bash scripts/run-in-dev-container.sh pnpm test:node",
        "lint:docker": "bash scripts/run-in-dev-container.sh pnpm lint",
        "clean": "node scripts/clean.mjs",
        "setup": "node scripts/setup.cjs || bash scripts/setup.sh",
        "setup:docker": "bash scripts/run-in-dev-container.sh pnpm install --no-frozen-lockfile",
        "analyze": "vite build --mode analyze"
    },
    "dependencies": {
        "@google/generative-ai": "^0.24.1",
