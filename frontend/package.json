    "devDependencies": {
        "@biomejs/biome": "2.4.14",
        "@tailwindcss/postcss": "^4.2.4",
        "@types/lodash": "^4.17.24",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/unist": "^3.0.3",
        "@types/video-react": "^0.15.8",
