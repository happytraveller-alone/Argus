        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "date-fns": "^4.1.0",
        "embla-carousel-react": "^8.6.0",
        "eventsource-parser": "^3.0.8",
        "fflate": "^0.8.2",
        "highlight.js": "^11.11.1",
        "input-otp": "^1.4.2",
        "ky": "^2.0.2",
        "lowlight": "^3.3.0",
        "lucide-react": "^1.14.0",
        "marked": "^18.0.3",
        "miaoda-sc-plugin": "^1.0.61",
