From 94ec73ff1d33926b75b811ded6f0b4a46088a7ec Mon Sep 17 00:00:00 2001
From: Gary Allan <github@gallan.co.uk>
Date: Sun, 27 Nov 2022 21:30:35 +0000
Subject: [PATCH] Bugfix: XSS (reflected) in 'bw-calulator-result.php';

Reported by ZenalArifin
---
 app/tools/ip-calculator/bw-calculator-result.php | 8 ++++----
 misc/CHANGELOG                                   | 4 ++++
 2 files changed, 8 insertions(+), 4 deletions(-)

diff --git a/app/tools/ip-calculator/bw-calculator-result.php b/app/tools/ip-calculator/bw-calculator-result.php
index 1e212db3..3445cf08 100644
--- a/app/tools/ip-calculator/bw-calculator-result.php
+++ b/app/tools/ip-calculator/bw-calculator-result.php
@@ -10,12 +10,12 @@ $User		= new User ($Database);
 $User->check_user_session();
 
 // process input values
-$tcp   = $_POST['wsize'];
-$delay = $_POST['delay'];
-$fsize = $_POST['fsize'];
+$tcp   = filter_var($_POST['wsize'], FILTER_VALIDATE_INT,   ["options" => ["min_range"=>1024, "max_range"=>65536]]) ?: die(_("Invalid input"));
+$delay = filter_var($_POST['delay'], FILTER_VALIDATE_FLOAT, ["options" => ["min_range"=>0.1,  "max_range"=>1000]])  ?: die(_("Invalid input"));
+$fsize = filter_var($_POST['fsize'], FILTER_VALIDATE_FLOAT, ["options" => ["min_range"=>100,  "max_range"=>4096]])  ?: die(_("Invalid input"));
 
 // get mbps values from config
-$mbps = round($tcp/($delay/1000)/(1024*1024),2);
+$mbps = round($tcp/($delay/1000)/(1024*1024), 4);
 
 // Calculate transfer time
 $time = round(($fsize / $mbps), 2);
diff --git a/misc/CHANGELOG b/misc/CHANGELOG
index a0463d88..c8e9c311 100755
--- a/misc/CHANGELOG
+++ b/misc/CHANGELOG
@@ -4,6 +4,10 @@
     ----------------------------
     + php8.1 compatibility (php8.x support is work-in-progress);
 
+    Security Fixes:
+    ----------------------------
+    + XSS (reflected) in 'bw-calulator-result.php';
+
 == 1.5.0
 
     New features:
-- 
2.34.1

