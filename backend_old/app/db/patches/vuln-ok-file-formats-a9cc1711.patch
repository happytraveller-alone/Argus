From e49cdfb84fb5eca2a6261f3c51a3c793fab9f62e Mon Sep 17 00:00:00 2001
From: David Brackeen <brackeen@gmail.com>
Date: Tue, 8 Jun 2021 05:45:28 -0700
Subject: [PATCH] ok_png: Disallow multiple IHDR chunks (#15)

---
 ok_png.c | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/ok_png.c b/ok_png.c
index 411d8f3..5bf8957 100644
--- a/ok_png.c
+++ b/ok_png.c
@@ -941,6 +941,10 @@ static void ok_png_decode2(ok_png_decoder *decoder) {
             return;
         }
         if (chunk_type == OK_PNG_CHUNK_IHDR) {
+            if (hdr_found) {
+                ok_png_error(png, OK_PNG_ERROR_INVALID, "Multiple IHDR chunks not allowed");
+                return;
+            }
             hdr_found = true;
             success = ok_png_read_header(decoder, chunk_length);
             if (success && info_only) {
-- 
