diff --git a/spec/support/servers/runner.rb b/spec/support/servers/runner.rb
new file mode 100644
index 0000000..ef6a3b9
--- /dev/null
+++ b/spec/support/servers/runner.rb
@@ -0,0 +1,17 @@
+module ServerRunner
+  def run_server(name, &block)
+    let! name do
+      server = block.call
+
+      Thread.new { server.start }
+
+      server
+    end
+
+    after do
+      send(name).shutdown
+    end
+  end
+end
+
+RSpec.configure { |c| c.extend ServerRunner }
