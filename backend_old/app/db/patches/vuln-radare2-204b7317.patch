From 204b7317beb1ede1ba352b13f7ebb09efff1c55d Mon Sep 17 00:00:00 2001
From: pancake <pancake@nopcode.org>
Date: Thu, 5 Dec 2019 17:43:57 +0100
Subject: [PATCH] Blindfix for #15543 - aka CVE-2019-19590

---
 libr/asm/asm.c | 6 ++++--
 1 file changed, 4 insertions(+), 2 deletions(-)

diff --git a/libr/asm/asm.c b/libr/asm/asm.c
index 2c1892f811dad..bd47a1a896660 100644
--- a/libr/asm/asm.c
+++ b/libr/asm/asm.c
@@ -753,13 +753,15 @@ R_API RAsmCode *r_asm_massemble(RAsm *a, const char *assembly) {
 			((ptr = strchr (tokens[ctr], ';')) ||
 			(ptr = strchr (tokens[ctr], '\n')) ||
 			(ptr = strchr (tokens[ctr], '\r')));) {
-		ctr++;
-		if (ctr >= tokens_size) {
+		if (ctr + 1 >= tokens_size) {
 			const int new_tokens_size = tokens_size * 2;
 			char **new_tokens = realloc (tokens, sizeof (char*) * new_tokens_size);
 			if (new_tokens) {
 				tokens_size = new_tokens_size;
 				tokens = new_tokens;
+				ctr++;
+			} else {
+				break;
 			}
 		}
 		*ptr = '\0';
