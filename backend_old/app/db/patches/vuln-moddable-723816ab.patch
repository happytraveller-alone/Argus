+		}
+		printer->tabs++;
+		(*node->description->dispatch->distribute)(node, fxNodePrintTree, param);
+		printer->tabs--;
 	}
-	printer->tabs++;
-	(*node->description->dispatch->distribute)(node, fxNodePrintTree, param);
