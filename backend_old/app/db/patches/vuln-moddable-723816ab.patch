-			fprintf(stderr, " super");
-		fprintf(stderr, " ]");
+	if (node) {
+		switch (node->description->token) {
+		case XS_TOKEN_ACCESS: 
+			fxAccessNodePrintNode(it); 
+			break;
+		case XS_TOKEN_ARG: 
+		case XS_TOKEN_CONST: 
