-	if (node->flags) {
-		fprintf(stderr, " [");
-		if (node->flags & mxArgumentsFlag)
-			fprintf(stderr, " arguments");
-		if (node->flags & mxArrowFlag)
-			fprintf(stderr, " arrow");
-		if (node->flags & mxAsyncFlag)
-			fprintf(stderr, " async");
