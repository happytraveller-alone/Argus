+			break;
+		case XS_TOKEN_FUNCTION: 
+			fxFunctionNodePrintNode(it); 
+			break;
+		case XS_TOKEN_LABEL: 
+			fxLabelNodePrintNode(it); 
+			break;
+		case XS_TOKEN_MEMBER: 
