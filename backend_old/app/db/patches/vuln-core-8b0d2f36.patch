From 8b0d2f36fd9ddb7a57ed3896a154f4e087e3d781 Mon Sep 17 00:00:00 2001
From: Will Ezell <will@dotcms.com>
Date: Tue, 28 May 2019 11:08:08 -0400
Subject: [PATCH] #16624 fixes unescaped sql call

---
 .../integritycheckers/AbstractIntegrityChecker.java | 13 ++++++-------
 1 file changed, 6 insertions(+), 7 deletions(-)

diff --git a/dotCMS/src/main/java/com/dotcms/integritycheckers/AbstractIntegrityChecker.java b/dotCMS/src/main/java/com/dotcms/integritycheckers/AbstractIntegrityChecker.java
index d1880674b1..a5d5267978 100644
--- a/dotCMS/src/main/java/com/dotcms/integritycheckers/AbstractIntegrityChecker.java
+++ b/dotCMS/src/main/java/com/dotcms/integritycheckers/AbstractIntegrityChecker.java
@@ -110,14 +110,13 @@ public abstract class AbstractIntegrityChecker implements IntegrityChecker {
      */
     private void discardConflicts(final String endpointId, IntegrityType type)
             throws DotDataException {
-        DotConnect dc = new DotConnect();
+
         final String resultsTableName = type.getResultsTableName();
-        try {
-            dc.executeStatement("delete from " + resultsTableName + " where endpoint_id = '"
-                    + endpointId + "'");
-        } catch (SQLException e) {
-            throw new DotDataException(e.getMessage(), e);
-        }
+        DotConnect dc = new DotConnect();
+        dc.setSQL("delete from " + resultsTableName + " where endpoint_id = ?")
+        .addParam(endpointId)
+        .loadResult();
+
     }
 
     /**
