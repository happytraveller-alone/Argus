From 5ac031b2ef5462f6e8e47dad0247bd474614c118 Mon Sep 17 00:00:00 2001
From: Harald Barth <haba@kth.se>
Date: Wed, 18 Dec 2019 20:55:21 -0700
Subject: [PATCH] Do not continue with launch if _become_user() fails.

If this failed, the step would launch as root instead of the desired
user, which could be exploited.

Bug 8084.

CVE-2019-19728.
---
 NEWS                        | 1 +
 src/srun/libsrun/srun_job.c | 4 ++--
 2 files changed, 3 insertions(+), 2 deletions(-)

diff --git a/NEWS b/NEWS
index 7f95057599..d380dd10a1 100644
--- a/NEWS
+++ b/NEWS
@@ -8,6 +8,7 @@ documents those changes that are of interest to users and administrators.
  -- Make Slurm compile on linux after sys/sysctl.h was deprecated.
  -- Install slurmdbd.conf.example with 0600 permissions to encourage secure
     use. CVE-2019-19727.
+ -- srun - do not continue with job launch if --uid fails. CVE-2019-19728.
 
 * Changes in Slurm 18.08.8
 ==========================
diff --git a/src/srun/libsrun/srun_job.c b/src/srun/libsrun/srun_job.c
index 619f422ac1..437dafe2c8 100644
--- a/src/srun/libsrun/srun_job.c
+++ b/src/srun/libsrun/srun_job.c
@@ -1286,7 +1286,7 @@ extern void create_srun_job(void **p_job, bool *got_alloc,
 		 *  Become --uid user
 		 */
 		if (_become_user () < 0)
-			info("Warning: Unable to assume uid=%u", opt.uid);
+			fatal("Unable to assume uid=%u", opt.uid);
 		if (_create_job_step(job, true, srun_job_list, pack_jobid,
 				     pack_nodelist) < 0) {
 			slurm_complete_job(my_job_id, 1);
@@ -1312,7 +1312,7 @@ extern void create_srun_job(void **p_job, bool *got_alloc,
 	 *  Become --uid user
 	 */
 	if (_become_user () < 0)
-		info("Warning: Unable to assume uid=%u", opt.uid);
+		fatal("Unable to assume uid=%u", opt.uid);
 
 	if (!slurm_started) {
 		/*
-- 
2.34.1

