From adb1eae912659d680a9c5b7832e22cf73d36a69a Mon Sep 17 00:00:00 2001
From: "Yukihiro \"Matz\" Matsumoto" <matz@ruby.or.jp>
Date: Thu, 28 Jun 2018 22:40:24 +0900
Subject: [PATCH] Use `mrb_raise()` instead of `mrb_raisef()`; ref #4062

---
 src/string.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/string.c b/src/string.c
index fd09e05dc..b7abfb762 100644
--- a/src/string.c
+++ b/src/string.c
@@ -709,7 +709,7 @@ mrb_str_resize(mrb_state *mrb, mrb_value str, mrb_int len)
   struct RString *s = mrb_str_ptr(str);
 
   if (len < 0) {
-    mrb_raisef(mrb, E_ARGUMENT_ERROR, "negative (or overflowed) string size");
+    mrb_raise(mrb, E_ARGUMENT_ERROR, "negative (or overflowed) string size");
   }
   mrb_str_modify(mrb, s);
   slen = RSTR_LEN(s);
-- 
2.34.1

