From 3ce16910be93b50cc83a3110903847fb6ca8a841 Mon Sep 17 00:00:00 2001
From: pmacdona <>
Date: Fri, 24 Dec 2021 15:37:20 +0000
Subject: [PATCH] Fix issue 69

FossilOrigin-Name: e84958b727a9abf4209dd7c6d785f065db3bd7fda673743203cf470a05ffbdb8
---
 Configs/make_memdebug.conf | 4 ++--
 src/jsiCmds.c              | 2 +-
 2 files changed, 3 insertions(+), 3 deletions(-)

diff --git a/Configs/make_memdebug.conf b/Configs/make_memdebug.conf
index 09ea158..c02c3b4 100644
--- a/Configs/make_memdebug.conf
+++ b/Configs/make_memdebug.conf
@@ -20,7 +20,7 @@ JSI__STUBS=1
 JSI__THREADS=1
 JSI__ZVFS=1
 JSI__MEMDEBUG=1
-JSI__SANITIZE=0
+JSI__SANITIZE=1
 WITH_EXT_SOCKET=1
 WITH_EXT_SQLITE=1
 WITH_EXT_WEBSOCKET=1
@@ -37,7 +37,7 @@ LINKSTATIC=0
 XCPREFIX=
 BUILDMODS=
 
-PROGFLAGS=  -DJSI__BASE64=1 -DJSI__CDATA=1 -DJSI__DEBUG=1 -DJSI__ENCRYPT=1 -DJSI__EVENT=1 -DJSI__FILESYS=1 -DJSI__INFO=1 -DJSI__LOAD=1 -DJSI__MATH=1 -DJSI__MD5=1 -DJSI__READLINE=1 -DJSI__SHA1=1 -DJSI__SHA256=1 -DJSI__SIGNAL=1 -DJSI__STUBS=1 -DJSI__THREADS=1 -DJSI__ZVFS=1 -DJSI__MEMDEBUG=1 -DJSI__MINIZ=1 -DJSI__REGEX=0 -DJSI__SANITIZE=0 -DJSI__SOCKET=1 -DJSI__SQLITE=1 -DJSI__WEBSOCKET=1 -DJSI__SQLITE=1 -DJSI__WEBSOCKET=1 -DJSI__MYSQL=0
+PROGFLAGS=  -DJSI__BASE64=1 -DJSI__CDATA=1 -DJSI__DEBUG=1 -DJSI__ENCRYPT=1 -DJSI__EVENT=1 -DJSI__FILESYS=1 -DJSI__INFO=1 -DJSI__LOAD=1 -DJSI__MATH=1 -DJSI__MD5=1 -DJSI__READLINE=1 -DJSI__SHA1=1 -DJSI__SHA256=1 -DJSI__SIGNAL=1 -DJSI__STUBS=1 -DJSI__THREADS=1 -DJSI__ZVFS=1 -DJSI__MEMDEBUG=1 -DJSI__MINIZ=1 -DJSI__REGEX=0 -DJSI__SANITIZE=1 -DJSI__SOCKET=1 -DJSI__SQLITE=1 -DJSI__WEBSOCKET=1 -DJSI__SQLITE=1 -DJSI__WEBSOCKET=1 -DJSI__MYSQL=0
 MODFLAGS= 
 
 # command: ./configure --ext=+sqlite,websocket --label=memdebug --opt=+sanitize,memdebug
diff --git a/src/jsiCmds.c b/src/jsiCmds.c
index 282d246..5357749 100644
--- a/src/jsiCmds.c
+++ b/src/jsiCmds.c
@@ -782,7 +782,7 @@ done:
 }
 
 Jsi_PkgOpts *Jsi_CommandPkgOpts(Jsi_Interp *interp, Jsi_Func *func) {
-    if (!func || func->type != FC_BUILDIN || !func->fobj->func->pkg) return NULL;
+    if (!func || func->type != FC_BUILDIN || !func->fobj || !func->fobj->func->pkg) return NULL;
     Jsi_PkgOpts *popts = &func->fobj->func->pkg->popts;
     return popts;
 }
