From 3fcf66c6031da966cf33ee89bcbefa2f8bec4b02 Mon Sep 17 00:00:00 2001
From: jeanlf <jeanlf@users.sourceforge.net>
Date: Fri, 5 Jul 2019 14:05:19 +0200
Subject: [PATCH] fixed potential crash cf #1262

---
 src/isomedia/box_code_base.c | 21 +++------------------
 1 file changed, 3 insertions(+), 18 deletions(-)

diff --git a/src/isomedia/box_code_base.c b/src/isomedia/box_code_base.c
index 668824693..878531b0b 100644
--- a/src/isomedia/box_code_base.c
+++ b/src/isomedia/box_code_base.c
@@ -8618,25 +8618,10 @@ void txtc_del(GF_Box *s)
 
 GF_Err txtc_Read(GF_Box *s, GF_BitStream *bs)
 {
-	u32 size, i;
-	char *str;
 	GF_TextConfigBox *ptr = (GF_TextConfigBox*)s;
-
-	size = (u32) ptr->size;
-	str = (char *)gf_malloc(sizeof(char)*size);
-
-	i=0;
-
-	while (size) {
-		str[i] = gf_bs_read_u8(bs);
-		size--;
-		if (!str[i])
-			break;
-		i++;
-	}
-	if (i) ptr->config = gf_strdup(str);
-	gf_free(str);
-
+	ptr->config = (char *)gf_malloc(sizeof(char)*((u32) ptr->size+1));
+	gf_bs_read_data(bs, ptr->config, (u32) ptr->size);
+	ptr->config[ptr->size] = 0;
 	return GF_OK;
 }
 
