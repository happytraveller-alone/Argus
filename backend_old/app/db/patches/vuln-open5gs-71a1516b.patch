         ogs_pfcp_header_t rsp;
 
         ogs_error("Not supported version[%d]", h->version);
diff --git a/src/smf/pfcp-path.c b/src/smf/pfcp-path.c
index e122513aa..b77ffbe22 100644
--- a/src/smf/pfcp-path.c
+++ b/src/smf/pfcp-path.c
@@ -120,7 +120,7 @@ static void pfcp_recv_cb(short when, ogs_socket_t fd, void *data)
     ogs_pkbuf_trim(pkbuf, size);
 
     h = (ogs_pfcp_header_t *)pkbuf->data;
-    if (h->version > OGS_PFCP_VERSION) {
+    if (h->version != OGS_PFCP_VERSION) {
         ogs_pfcp_header_t rsp;
 
         ogs_error("Not supported version[%d]", h->version);
diff --git a/src/upf/pfcp-path.c b/src/upf/pfcp-path.c
index 13cc1bb44..2b188d2e7 100644
--- a/src/upf/pfcp-path.c
+++ b/src/upf/pfcp-path.c
@@ -83,7 +83,7 @@ static void pfcp_recv_cb(short when, ogs_socket_t fd, void *data)
     ogs_pkbuf_trim(pkbuf, size);
 
     h = (ogs_pfcp_header_t *)pkbuf->data;
-    if (h->version > OGS_PFCP_VERSION) {
+    if (h->version != OGS_PFCP_VERSION) {
         ogs_pfcp_header_t rsp;
 
         ogs_error("Not supported version[%d]", h->version);
