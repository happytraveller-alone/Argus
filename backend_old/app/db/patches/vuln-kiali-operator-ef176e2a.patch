-# Now deploy all resources for the specific cluster environment
-
-- name: Execute for OpenShift environment
-  include: openshift/os-main.yml
-  when:
-  - is_openshift == True
-
-- name: Execute for Kubernetes environment
-  include: kubernetes/k8s-main.yml
-  when:
-  - is_k8s == True
