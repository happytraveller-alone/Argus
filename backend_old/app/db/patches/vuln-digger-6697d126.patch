Date: Wed, 25 Aug 2021 16:54:38 +0200
Subject: [PATCH] Disable entities while parsing XML

---
 remove_leading_place.py | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/remove_leading_place.py b/remove_leading_place.py
index 29ba11b..0760b75 100755
--- a/remove_leading_place.py
+++ b/remove_leading_place.py
@@ -44,7 +44,8 @@ def ocr_to_dict(url):
 
     parser = lxml.etree.XMLParser(ns_clean=True,
                                   recover=True,
-                                  encoding='utf-8')
+                                  encoding='utf-8',
+                                  resolve_entities=False)
 
     xml = lxml.etree.fromstring(text, parser=parser)
 
