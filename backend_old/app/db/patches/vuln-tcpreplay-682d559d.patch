From 5113429140250e9640c3eca1be7745ff8380d363 Mon Sep 17 00:00:00 2001
From: Fred Klassen <fklassen@appneta.com>
Date: Mon, 1 Jun 2020 14:48:30 -0700
Subject: [PATCH] Bug #578 fix nits in configure.ac

---
 configure.ac              |  4 ++--
 docs/CHANGELOG            |  3 ++-
 src/tcpedit/edit_packet.c | 12 ------------
 3 files changed, 4 insertions(+), 15 deletions(-)

diff --git a/configure.ac b/configure.ac
index 2dae54ac..14b283fe 100644
--- a/configure.ac
+++ b/configure.ac
@@ -66,7 +66,7 @@ dnl Check OS X SDK and compiler
 dnl ===========================
 
 case "$host_os" in
-    *darwin*) # Mac OS X or iOS
+    darwin*) # Mac OS X or iOS
         # If no --with-macosx-sdk option is given, look for one
 
         # The intent is that for "most" Mac-based developers, a suitable
@@ -106,7 +106,7 @@ case "$host_os" in
             AC_MSG_RESULT([legacy])
         fi
         ;;
-    *Linux*)
+    Linux*)
         dnl ============================================
         dnl Some libraries are in /usr/lib/i386-linux-gnu
         dnl but host is i686-linux-gnu
diff --git a/docs/CHANGELOG b/docs/CHANGELOG
index b0addb80..bf500311 100644
--- a/docs/CHANGELOG
+++ b/docs/CHANGELOG
@@ -1,6 +1,7 @@
 05/20/2020 Version 4.3.3 beta1
     - Correct L2 header length to correct IP header offset (#583)
-    - fix warnings from gcc version 10 (#580)
+    - Fix warnings from gcc version 10 (#580)
+    - Use after free in get_ipv6_next (#578)
 
 03/12/2019 Version 4.3.2
     - CVE-2019-8381 memory access in do_checksum() (#538)
diff --git a/src/tcpedit/edit_packet.c b/src/tcpedit/edit_packet.c
index d3efeb01..f8690aaa 100644
--- a/src/tcpedit/edit_packet.c
+++ b/src/tcpedit/edit_packet.c
@@ -77,19 +77,7 @@ fix_ipv4_checksums(tcpedit_t *tcpedit, struct pcap_pkthdr *pkthdr, ipv4_hdr_t *i
     /* calc the L4 checksum if we have the whole packet && not a frag or first frag */
     if (pkthdr->caplen == pkthdr->len &&
             (htons(ip_hdr->ip_off) & (IP_MF | IP_OFFMASK)) == 0) {
-        if (ntohs(ip_hdr->ip_len) < (ip_hdr->ip_hl << 2)) {
-            tcpedit_setwarn(tcpedit, "Unable to checksum IPv4 packet with invalid length %u",
-                    ip_hdr->ip_len);
-            return TCPEDIT_WARN;
-        }
-
         ip_len = (int)ntohs(ip_hdr->ip_len);
-        if (ip_len < (int)pkthdr->caplen) {
-            tcpedit_seterr(tcpedit, "Corrupt packet: Unable to checksum IPv4 packet with invalid length %u",
-                    ip_len);
-            return TCPEDIT_ERROR;
-        }
-
         ret1 = do_checksum(tcpedit, (u_char *) ip_hdr, ip_hdr->ip_p,
                 ip_len - (ip_hdr->ip_hl << 2));
         if (ret1 < 0)
-- 
2.34.1

