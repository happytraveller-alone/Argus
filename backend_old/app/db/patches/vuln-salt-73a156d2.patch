From 73a156d28cafd45dcc6c2aac9f1ac3ad905695e3 Mon Sep 17 00:00:00 2001
From: Erik Johnson <palehose@gmail.com>
Date: Wed, 20 Jul 2016 01:51:59 -0500
Subject: [PATCH] Support enforcement of file mode in RemoteClient and
 LocalClient

This code modifies the file caching code in both fileclients to request
the stat result for the desired file. If the locally-cached copy of the
file has a mode which does not match the mode retrieved from the
fileclient, then the cached copy's mode is chmod'ed to match.
---
 salt/fileclient.py | 230 ++++++++++++++++++++++++++++++++++++++-------
 1 file changed, 194 insertions(+), 36 deletions(-)

diff --git a/salt/fileclient.py b/salt/fileclient.py
index 5972a10072..d2d2d084c7 100644
--- a/salt/fileclient.py
+++ b/salt/fileclient.py
@@ -7,7 +7,6 @@ from __future__ import absolute_import
