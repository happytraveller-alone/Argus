From 830d9530817516377c2bc3b532798ce2c6b4765a Mon Sep 17 00:00:00 2001
From: Ken Murchison <murch@andrew.cmu.edu>
Date: Fri, 2 Dec 2016 15:04:56 -0500
Subject: [PATCH] icalparser.c: don't create two ICAL_XLICINVALID_COMPONENT for
 an invalid component

---
 src/libical/icalparser.c | 6 ------
 1 file changed, 6 deletions(-)

diff --git a/src/libical/icalparser.c b/src/libical/icalparser.c
index 2735c9ac..36778909 100644
--- a/src/libical/icalparser.c
+++ b/src/libical/icalparser.c
@@ -713,12 +713,6 @@ icalcomponent *icalparser_add_line(icalparser *parser, char *line)
 
         comp_kind = icalenum_string_to_component_kind(str);
 
-        if (comp_kind == ICAL_NO_COMPONENT) {
-            c = icalcomponent_new(ICAL_XLICINVALID_COMPONENT);
-            insert_error(c, str, "Parse error in component name",
-                         ICAL_XLICERRORTYPE_COMPONENTPARSEERROR);
-        }
-
         c = icalcomponent_new(comp_kind);
 
         if (c == 0) {
-- 
2.34.1

