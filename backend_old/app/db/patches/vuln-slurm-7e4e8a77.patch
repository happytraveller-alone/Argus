From 7e4e8a77c97bcdc5fa2803762f25318f40107ed4 Mon Sep 17 00:00:00 2001
From: Tim Wickberg <tim@schedmd.com>
Date: Tue, 28 Nov 2023 23:39:21 -0700
Subject: [PATCH] Use safe_unpackstr() to escape strings into slurmdbd
 properly.

CVE-2023-49934.
---
 NEWS                             | 1 +
 src/common/slurm_protocol_pack.c | 6 ++++--
 2 files changed, 5 insertions(+), 2 deletions(-)

diff --git a/NEWS b/NEWS
index 45ff035cabf..0319d0c011c 100644
--- a/NEWS
+++ b/NEWS
@@ -72,6 +72,7 @@ documents those changes that are of interest to users and administrators.
     count that differs from the number of unique nodes in the hostlist.
  -- Prevent slurmdbd errors when updating reservations with names containing
     apostrophes.
+ -- Prevent SQL injection attacks in slurmdbd. CVE-2023-49934.
 
 * Changes in Slurm 23.11.0
 ==========================
diff --git a/src/common/slurm_protocol_pack.c b/src/common/slurm_protocol_pack.c
index 8cb7e62dcc8..c26c170429c 100644
--- a/src/common/slurm_protocol_pack.c
+++ b/src/common/slurm_protocol_pack.c
@@ -449,9 +449,11 @@ static void _pack_shares_request_msg(const slurm_msg_t *smsg, buf_t *buffer)
 extern int unpackstr_with_version(void **object, uint16_t protocol_version,
 				  buf_t *buffer)
 {
-	uint32_t uint32_tmp;
+	safe_unpackstr((char **) object, buffer);
+	return SLURM_SUCCESS;
 
-	return unpackstr_xmalloc((char **) object, &uint32_tmp, buffer);
+unpack_error:
+	return SLURM_ERROR;
 }
 
 static int _unpack_shares_request_msg(slurm_msg_t *smsg, buf_t *buffer)
