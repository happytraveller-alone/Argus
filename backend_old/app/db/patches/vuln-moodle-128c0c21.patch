From 128c0c21607a71f411611a0104b2a8c858dd6fca Mon Sep 17 00:00:00 2001
From: Lars Bonczek <bonczek@math.tu-berlin.de>
Date: Tue, 6 Sep 2022 15:55:11 +0200
Subject: [PATCH] MDL-75659 core: Don't render component argument twice in
 mustache pix helper

---
 lib/classes/output/mustache_pix_helper.php | 1 -
 1 file changed, 1 deletion(-)

diff --git a/lib/classes/output/mustache_pix_helper.php b/lib/classes/output/mustache_pix_helper.php
index 3de09778a6e..9bc374d1414 100644
--- a/lib/classes/output/mustache_pix_helper.php
+++ b/lib/classes/output/mustache_pix_helper.php
@@ -68,7 +68,6 @@ class mustache_pix_helper {
         if (!$component) {
             $component = '';
         }
-        $component = $helper->render($component);
         $text = strtok("");
         // Allow mustache tags in the last argument.
         $text = trim($helper->render($text));
-- 
