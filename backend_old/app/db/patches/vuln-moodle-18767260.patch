From 187672608ec96659e07f2461b3b83634debd16cb Mon Sep 17 00:00:00 2001
From: Rajesh Taneja <rajesh@moodle.org>
Date: Mon, 7 Nov 2011 15:18:32 +0800
Subject: [PATCH] MDL-28947 lib: print_object cleans html special chars before
 printing

---
 lib/datalib.php | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/lib/datalib.php b/lib/datalib.php
index 88066531899..e888b23149d 100644
--- a/lib/datalib.php
+++ b/lib/datalib.php
@@ -1954,7 +1954,9 @@ function count_login_failures($mode, $username, $lastlogin) {
  */
 function print_object($object) {
     echo '<pre class="notifytiny">';
-    print_r($object);  // Direct to output because some objects get too big for memory otherwise!
+    // we may need a lot of memory here
+    raise_memory_limit(MEMORY_EXTRA);
+    echo s(print_r($object, true));
     echo '</pre>';
 }
 
