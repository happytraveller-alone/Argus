 				'default' => self::EMAIL_PATTERN
diff --git a/decoda/filters/UrlFilter.php b/decoda/filters/UrlFilter.php
index 5d4f6ec..23a0014 100644
--- a/decoda/filters/UrlFilter.php
+++ b/decoda/filters/UrlFilter.php
@@ -29,6 +29,7 @@ class UrlFilter extends DecodaFilter {
 			'type' => self::TYPE_INLINE,
 			'allowed' => self::TYPE_INLINE,
 			'pattern' => self::URL_PATTERN,
+			'testNoDefault' => true,
 			'attributes' => array(
 				'default' => self::URL_PATTERN
 			),
@@ -41,6 +42,7 @@ class UrlFilter extends DecodaFilter {
 			'type' => self::TYPE_INLINE,
 			'allowed' => self::TYPE_INLINE,
 			'pattern' => self::URL_PATTERN,
