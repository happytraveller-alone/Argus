 			'attributes' => array(
 				'default' => self::URL_PATTERN
 			),
@@ -59,8 +61,8 @@ class UrlFilter extends DecodaFilter {
 	 * @return string
 	 */
 	public function parse(array $tag, $content) {
-		if (empty($tag['attributes']['default'])) {
-			$tag['attributes']['default'] = $content;
+		if (empty($tag['attributes']['href']) && empty($tag['attributes']['default'])) {
+			$tag['attributes']['href'] = $content;
 		}
 
 		if ($this->getParser()->config('shorthand')) {
diff --git a/decoda/filters/VideoFilter.php b/decoda/filters/VideoFilter.php
index bdce778..86332a9 100644
--- a/decoda/filters/VideoFilter.php
+++ b/decoda/filters/VideoFilter.php
@@ -29,7 +29,6 @@ class VideoFilter extends DecodaFilter {
 			'type' => self::TYPE_BLOCK,
 			'allowed' => self::TYPE_NONE,
 			'pattern' => self::VIDEO_PATTERN,
-			'patternFor' => 'content',
 			'attributes' => array(
 				'default' => '/[a-z0-9]+/i',
 				'size' => '/small|medium|large/i'
@@ -115,7 +114,7 @@ public function parse(array $tag, $content) {
 		$size = strtolower(isset($tag['attributes']['size']) ? $tag['attributes']['size'] : 'medium');
 
 		if (empty($this->_formats[$provider])) {
-			return $provider . ':' . $content;
+			return sprintf('(Invalid %s video code)', $provider);
 		}
 
 		$video = $this->_formats[$provider];
@@ -126,8 +125,6 @@ public function parse(array $tag, $content) {
 		$tag['attributes']['player'] = $video['player'];
 		$tag['attributes']['url'] = str_replace(array('{id}', '{width}', '{height}'), array($content, $size[0], $size[1]), $video['path']);
 
-		// XSS prevention
-
 		return parent::parse($tag, $content);
 	}
 
