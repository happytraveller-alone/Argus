From ae831621a08a64e3325ce532f8b78811a1581716 Mon Sep 17 00:00:00 2001
From: Aurelien David <aurelien.david@telecom-paristech.fr>
Date: Tue, 27 Feb 2024 14:00:16 +0100
Subject: [PATCH] swf_parse fix for size=0 (fixes #2764)

---
 src/scene_manager/swf_parse.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/scene_manager/swf_parse.c b/src/scene_manager/swf_parse.c
index 96d927469..a8448c413 100644
--- a/src/scene_manager/swf_parse.c
+++ b/src/scene_manager/swf_parse.c
@@ -322,7 +322,7 @@ static char *swf_get_string(SWFReader *read)
 	while (1) {
 		if (i>=read->size) {
 			read->ioerr = GF_NON_COMPLIANT_BITSTREAM;
-			name[read->size-1] = 0;
+			name[read->size ? read->size-1 : 0] = 0;
 			break;
 		}
 		name[i] = swf_read_int(read, 8);
