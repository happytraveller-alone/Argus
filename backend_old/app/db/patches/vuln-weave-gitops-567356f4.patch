From 567356f471353fb5c676c77f5abc2a04631d50ca Mon Sep 17 00:00:00 2001
From: Stefan Prodan <stefan.prodan@gmail.com>
Date: Sat, 28 May 2022 15:43:50 +0300
Subject: [PATCH] Fix logging on cluster connection error Remove the client
 config from the error log since the wrapped error already contains the
 cluster name for which the connection couldn't be established.

Signed-off-by: Stefan Prodan <stefan.prodan@gmail.com>
---
 core/clustersmngr/factory.go | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/core/clustersmngr/factory.go b/core/clustersmngr/factory.go
index 513eda59..b7bc2c84 100644
--- a/core/clustersmngr/factory.go
+++ b/core/clustersmngr/factory.go
@@ -131,7 +131,7 @@ func (cf *clientsFactory) watchNamespaces(ctx context.Context) {
 func (cf *clientsFactory) UpdateNamespaces(ctx context.Context) error {
 	clients, err := clientsForClusters(cf.clusters.Get())
 	if err != nil {
-		cf.log.Error(err, "failed to create clients for", "clusters", cf.clusters.Get())
+		cf.log.Error(err, "failed to create client")
 		return err
 	}
 
-- 
2.34.1

