+  case TS_EVENT_HTTP_READ_RESPONSE_HDR:
+    config->getPolicy()->addBytes(txnp);
+    break;
+
+  case TS_EVENT_HTTP_TXN_CLOSE:
+    config->getPolicy()->cleanup(txnp);
+    break;
+
   // Should not happen
