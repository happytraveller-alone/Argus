From 8259e7bc31edbf702ee0131cf9bd0b0ab09e93fb Mon Sep 17 00:00:00 2001
From: Frederic Lepied <frederic.lepied@enovance.com>
Date: Tue, 21 Oct 2014 17:54:23 +0200
Subject: [PATCH] server/upload*.py,build/init*: switch from a python file for
 hardware detection dict to a json one.

---
 build/init              |  6 +++---
 build/init.common       |  6 +++---
 build/init.health       | 14 +++++++-------
 server/try_match        |  6 +++---
 server/upload-health.py |  3 ++-
 server/upload.py        |  8 +++++++-
 src/detect.py           |  4 ++--
 src/health-check.py     |  9 +++++++--
 src/health-client.py    | 16 +++++++++++-----
 9 files changed, 45 insertions(+), 27 deletions(-)

diff --git a/build/init b/build/init
index affedc99..97aa9a1d 100755
--- a/build/init
+++ b/build/init
@@ -161,10 +161,10 @@ if [ -n "$EMBEDDED" ]; then
     dmesg > $EMBEDDED_MOUNT/var/lib/edeploy/config/logs/${vendor}-${product}-${serial}.dmesg
     mkdir -p /etc/
     cp -a $EMBEDDED_MOUNT/etc/* /etc
-    do_python "/upload.py -f /hw.py" > /configure
+    do_python "/upload.py -f /hw.json" > /configure
 else
     step "Configuring system via server ${SERV}"
-    curl -s -S -o/configure -F section=${SECTION} -F file=@/hw.py http://${SERV}:${HTTP_PORT}/${HTTP_PATH}/upload.py &
+    curl -s -S -o/configure -F section=${SECTION} -F file=@/hw.json http://${SERV}:${HTTP_PORT}/${HTTP_PATH}/upload.py &
     # Saving curl's PID
     PID="$!"
 
@@ -256,7 +256,7 @@ if /configure; then
         if [ -d $d/var/log ]; then
             mkdir -p $d/var/log/edeploy
             cp -p /log $d/var/log/edeploy/install.log
-            cp -p /vars /hw.py $d/var/log/edeploy
+            cp -p /vars /hw.json $d/var/log/edeploy
             cp -p /configure $d/var/log/edeploy
             dmesg > $d/var/log/edeploy/dmesg
         fi
diff --git a/build/init.common b/build/init.common
index 1fdc95b2..f0a94add 100644
--- a/build/init.common
+++ b/build/init.common
@@ -57,7 +57,7 @@ do_python() {
 }
 
 run_detect() {
-    do_python /detect.py > /hw.py || give_up "Failed to detect hardware"
+    do_python /detect.py > /hw.json || give_up "Failed to detect hardware"
 }
 
 get_system_info() {
@@ -288,10 +288,10 @@ report_failure() {
     if [ -n "$CAN_REPORT_FAILURE" ]; then
         if [ -n "$EMBEDDED" ]; then
             log "Reporting failure to reincrement profile's quantities"
-            /upload.py -f /hw.py -F $PROFILE
+            /upload.py -f /hw.json -F $PROFILE
         else
             log "Reporting failure to reincrement profile's quantities on server $SERV"
-            curl -s -S -F section=${SECTION} -F failure=$PROFILE -F file=@/hw.py http://${SERV}:${HTTP_PORT}/${HTTP_PATH}/upload.py
+            curl -s -S -F section=${SECTION} -F failure=$PROFILE -F file=@/hw.json http://${SERV}:${HTTP_PORT}/${HTTP_PATH}/upload.py
         fi
     fi
 }
diff --git a/build/init.health b/build/init.health
index fd5f7e21..98668212 100755
--- a/build/init.health
+++ b/build/init.health
@@ -54,7 +54,7 @@ fi
 ################################################################################
 
 step "Saving benchmark results via server ${SERV}"
-curl -s -S $SESSION_CURL -F file=@/health.py http://${SERV}:${HTTP_PORT}/${HTTP_PATH}/upload-health.py &
+curl -s -S $SESSION_CURL -F file=@/health.json http://${SERV}:${HTTP_PORT}/${HTTP_PATH}/upload-health.py &
 #Saving curl's PID
 PID="$!"
 
@@ -198,7 +198,7 @@ show_git_rev
 if [ -n "$RBENCH" ]; then
     step "Contacting Benchmark Server ($RBENCH)"
     while true; do
-        do_python "/health-client.py /hw.py $RBENCH"
+        do_python "/health-client.py /hw.json $RBENCH"
         if [ $? -eq 0 ]; then
             break;
         fi
@@ -206,25 +206,25 @@ if [ -n "$RBENCH" ]; then
     done
 else
     step "Benchmarking system"
-    do_python "/health-check.py /hw.py" > /health.py || give_up "Failed to run health-check"
+    do_python "/health-check.py /hw.json" > /health.json || give_up "Failed to run health-check"
 
     save_results
 
     if [ ! -z "$SMOKE" ]; then
         step "Entering Smoke Test for $SMOKE minutes"
         (while true; do
-            do_python "/health-check.py hw.py storage-burn" &>/dev/null;
+            do_python "/health-check.py hw.json storage-burn" &>/dev/null;
         done
         ) &
         PID_STORAGE="$!"
         PID_CPU="$!"
         (while true; do
-            do_python "/health-check.py hw.py memory-burn" &>/dev/null;
+            do_python "/health-check.py hw.json memory-burn" &>/dev/null;
         done
         ) &
         PID_MEMORY="$!"
         (while true; do
-            do_python "/health-check.py hw.py cpu-burn" &>/dev/null;
+            do_python "/health-check.py hw.json cpu-burn" &>/dev/null;
         done
         ) &
         PID_CPU="$!"
@@ -241,7 +241,7 @@ else
 
         step "Benchmarking after Smoke test"
         sleep 10
-        do_python "/health-check.py hw.py" > /health.py
+        do_python "/health-check.py hw.json" > /health.json
 
         save_results
     fi
