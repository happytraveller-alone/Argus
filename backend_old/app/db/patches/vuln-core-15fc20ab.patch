From: Jonathan Gamba <jonathan.gamba@dotcms.com>
Date: Thu, 20 Sep 2018 11:22:33 -0600
Subject: [PATCH] #15274 (#15321)

---
 .../filters/interceptor/SimpleWebInterceptorDelegateImpl.java  | 3 ++-
 .../dotcms/DefaultBackEndLoginRequiredWebInterceptor.java      | 2 +-
 2 files changed, 3 insertions(+), 2 deletions(-)

diff --git a/dotCMS/src/main/java/com/dotcms/filters/interceptor/SimpleWebInterceptorDelegateImpl.java b/dotCMS/src/main/java/com/dotcms/filters/interceptor/SimpleWebInterceptorDelegateImpl.java
index 98ea43ba06..2964ad37dc 100644
--- a/dotCMS/src/main/java/com/dotcms/filters/interceptor/SimpleWebInterceptorDelegateImpl.java
+++ b/dotCMS/src/main/java/com/dotcms/filters/interceptor/SimpleWebInterceptorDelegateImpl.java
@@ -173,7 +173,8 @@ public class SimpleWebInterceptorDelegateImpl implements WebInterceptorDelegate
 
                 // if the filter applies just for some filter patterns.
                 if (webInterceptor.isActive() &&
-                        this.anyMatchFilter(webInterceptor, request.getRequestURI())) {
+                        this.anyMatchFilter(webInterceptor,
+                                request.getRequestURI().toLowerCase())) {
 
                     result          = webInterceptor.intercept(request, response);
                     shouldContinue &= (Result.SKIP_NO_CHAIN != result);
diff --git a/dotCMS/src/main/java/com/dotcms/filters/interceptor/dotcms/DefaultBackEndLoginRequiredWebInterceptor.java b/dotCMS/src/main/java/com/dotcms/filters/interceptor/dotcms/DefaultBackEndLoginRequiredWebInterceptor.java
index 4b26c92a15..e263d42f0d 100644
--- a/dotCMS/src/main/java/com/dotcms/filters/interceptor/dotcms/DefaultBackEndLoginRequiredWebInterceptor.java
+++ b/dotCMS/src/main/java/com/dotcms/filters/interceptor/dotcms/DefaultBackEndLoginRequiredWebInterceptor.java
@@ -34,7 +34,7 @@ public class DefaultBackEndLoginRequiredWebInterceptor implements WebInterceptor
 
     @Override
     public String[] getFilters() {
-        return new String[]{"/html"};
+        return new String[]{"/html/"};
     }
 
     @Override
