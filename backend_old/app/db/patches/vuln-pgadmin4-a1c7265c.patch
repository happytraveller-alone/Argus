 web/pgadmin/utils/driver/psycopg3/__init__.py             | 4 ++--
 12 files changed, 18 insertions(+), 18 deletions(-)

diff --git a/.pycodestyle b/.pycodestyle
index 598d49564..376af57e9 100644
--- a/.pycodestyle
+++ b/.pycodestyle
@@ -1,5 +1,5 @@
 [pycodestyle]
-ignore = E402,W504,W605
+ignore = E402,W504,W605,E231,W605
 max-line-length = 79
 statistics = True
 show-source = False
diff --git a/web/pgacloud/utils/misc.py b/web/pgacloud/utils/misc.py
index 67b645721..d00bd070b 100644
--- a/web/pgacloud/utils/misc.py
+++ b/web/pgacloud/utils/misc.py
@@ -24,7 +24,7 @@ def get_my_ip():
         except Exception:
             external_ip = '127.0.0.1'
 
-    if type(external_ip) == bytes:
+    if isinstance(external_ip, bytes):
         external_ip = external_ip.decode('utf-8')
 
     ip = ipaddress.ip_address(external_ip)
