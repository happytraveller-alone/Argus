From caade60a69633d74100bd3c2528bddee0b6a1291 Mon Sep 17 00:00:00 2001
From: Marsman1996 <lqliuyuwei@outlook.com>
Date: Thu, 16 Dec 2021 14:22:30 +0800
Subject: [PATCH] exit program when bmp file is oversize

---
 src/ffjpeg.c | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/src/ffjpeg.c b/src/ffjpeg.c
index c1b23fe..a90b59a 100644
--- a/src/ffjpeg.c
+++ b/src/ffjpeg.c
@@ -26,7 +26,10 @@ int main(int argc, char *argv[])
         bmp_save(&bmp, "decode.bmp");
         bmp_free(&bmp);
     } else if (strcmp(argv[1], "-e") == 0) {
-        bmp_load(&bmp, argv[2]);
+        if (bmp_load(&bmp, argv[2]) == -1) {
+            printf("failed to load bmp file: %s !\n", argv[2]);
+            return -1;
+        }
         jfif = jfif_encode(&bmp);
         bmp_free(&bmp);
         jfif_save(jfif, "encode.jpg");
-- 
