From d425866375c85038133a6f79db2aac66c0a72624 Mon Sep 17 00:00:00 2001
From: Saeed Seyfi <saeeds@spotify.com>
Date: Wed, 4 Jan 2023 17:43:01 +0100
Subject: [PATCH] fixes(CVE-2022-25923): resolves command injection security
 issue

---
 index.js     | 19 +++++++++++++++++--
 package.json |  6 ++++++
 2 files changed, 23 insertions(+), 2 deletions(-)

diff --git a/index.js b/index.js
index fe9068e..46bbfe0 100644
--- a/index.js
+++ b/index.js
@@ -1,8 +1,23 @@
 const exec = require('child_process').exec;
+const fs = require('fs');
+const path = require('path');
 
 module.exports = async function (bin, options) {
-    return new Promise((resolve, reject) => {
-        const cmd = `${process.cwd()}/node_modules/.bin/${bin}`;
+    return new Promise(async (resolve, reject) => {
+        const binDir = `${process.cwd()}/node_modules/.bin`;
+        const cmd = path.join(binDir, bin);
+
+        if (!cmd.startsWith(binDir)) {
+            reject(new Error(`${cmd} within the expected directory`));
+            return;
+        }
+
+        try {
+            await fs.access(cmd, fs.constants.X_OK);
+        } catch (err) {
+            reject(new Error(`${cmd} is not accessible: ${err.message}`));
+            return;
+        }
 
         console.log(`Running \`${cmd}\``);
 
diff --git a/package.json b/package.json
index 3aa1ce9..a765c17 100644
--- a/package.json
+++ b/package.json
@@ -3,6 +3,12 @@
   "version": "1.1.1",
   "description": "Helps you run local node binaries in node",
   "main": "index.js",
+  "files": [
+    "index.js"
+  ],
+  "engines": {
+    "node": "^8.0.0"
+  },
   "scripts": {
     "test": "echo \"Error: no test specified\" && exit 1"
   },
-- 
