From 83dadd3def6d2e7e75fc003a5ab409aa81275dd8 Mon Sep 17 00:00:00 2001
From: Peter Hoddie <peter@moddable.tech>
Date: Wed, 29 Dec 2021 07:53:44 -0800
Subject: [PATCH] ASAN stack margin: move to make file, increase #761

---
 xs/makefiles/mac/xst.mk |  2 +-
 xs/sources/xsCommon.c   | 10 +++++++---
 2 files changed, 8 insertions(+), 4 deletions(-)

diff --git a/xs/makefiles/mac/xst.mk b/xs/makefiles/mac/xst.mk
index e43eacd28..02a55bc5c 100644
--- a/xs/makefiles/mac/xst.mk
+++ b/xs/makefiles/mac/xst.mk
@@ -76,7 +76,7 @@ ifneq ("x$(SDKROOT)", "x")
 endif
 
 ifeq ($(GOAL),debug)
-	C_OPTIONS += -fsanitize=address -fno-omit-frame-pointer
+	C_OPTIONS += -fsanitize=address -fno-omit-frame-pointer -DmxASANStackMargin=32768
 	LINK_OPTIONS += -fsanitize=address -fno-omit-frame-pointer
 endif
 
diff --git a/xs/sources/xsCommon.c b/xs/sources/xsCommon.c
index 39b3cb7fb..2fe296908 100644
--- a/xs/sources/xsCommon.c
+++ b/xs/sources/xsCommon.c
@@ -515,24 +515,28 @@ const txS1 gxCodeSizes[XS_CODE_COUNT] ICACHE_FLASH_ATTR = {
 
 #if mxUseDefaultCStackLimit
 
+#ifndef mxASANStackMargin
+	#define mxASANStackMargin 0
+#endif
+
 char* fxCStackLimit()
 {
 	#if mxWindows
 		ULONG_PTR low, high;
 		GetCurrentThreadStackLimits(&low, &high);
-		return (char*)low + (32 * 1024);
+		return (char*)low + (16 * 1024) + mxASANStackMargin;
 	#elif mxMacOSX
 		pthread_t self = pthread_self();
     	void* stackAddr = pthread_get_stackaddr_np(self);
    		size_t stackSize = pthread_get_stacksize_np(self);
-		return (char*)stackAddr - stackSize + (32 * 1024);
+		return (char*)stackAddr - stackSize + (16 * 1024) + mxASANStackMargin;
 	#elif mxLinux
 		pthread_attr_t attrs;
 		if (pthread_getattr_np(pthread_self(), &attrs) == 0) {
     		void* stackAddr;
    			size_t stackSize;
 			if (pthread_attr_getstack(&attrs, &stackAddr, &stackSize) == 0) {
-				return (char*)stackAddr + (32 * 1024);
+				return (char*)stackAddr + (16 * 1024) + mxASANStackMargin;
 			}
 		}
 		return C_NULL;
-- 
2.34.1

