     /**
      */
-    public $version = 'H5 (3.0.12-git)';
+    public $version = 'H5 (3.0.12)';
 
     /**
      * Server key used in logged out session.
diff --git a/gollem/package.xml b/gollem/package.xml
index 2562b8cae3..34b81947dc 100644
--- a/gollem/package.xml
+++ b/gollem/package.xml
