From 3268f95282d4f99d6cec3a6e0a83f341cf48166a Mon Sep 17 00:00:00 2001
From: Isaac Connor <isaac@zoneminder.com>
Date: Mon, 20 Feb 2023 09:18:51 -0500
Subject: [PATCH] Fix detaintPath not stripping sequences like ..././

---
 web/includes/functions.php | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/web/includes/functions.php b/web/includes/functions.php
index c3af85665e..797353009d 100644
--- a/web/includes/functions.php
+++ b/web/includes/functions.php
@@ -1873,7 +1873,9 @@ function generateConnKey() {
 
 function detaintPath($path) {
   // Remove any absolute paths, or relative ones that want to go up
-  $path = str_replace('../', '', $path);
+  do {
+    $path = str_replace('../', '', $path, $count);
+  } while($count);
   $path = ltrim($path, '/');
   return $path;
 }
