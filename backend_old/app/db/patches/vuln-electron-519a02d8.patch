From 519a02d8d4d28e8a467acb40fb26172a80c9454f Mon Sep 17 00:00:00 2001
From: Samuel Attard <samuel.r.attard@gmail.com>
Date: Wed, 22 Aug 2018 12:21:53 -0500
Subject: [PATCH] fix: inheritance of webPreferences sub properties

---
 lib/browser/guest-window-manager.js | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/lib/browser/guest-window-manager.js b/lib/browser/guest-window-manager.js
index 272d29f961..6ff9e5f530 100644
--- a/lib/browser/guest-window-manager.js
+++ b/lib/browser/guest-window-manager.js
@@ -26,11 +26,11 @@ const mergeOptions = function (child, parent, visited) {
   visited.add(parent)
   for (const key in parent) {
     if (!hasProp.call(parent, key)) continue
-    if (key in child) continue
+    if (key in child && key !== 'webPreferences') continue
 
     const value = parent[key]
     if (typeof value === 'object') {
-      child[key] = mergeOptions({}, value, visited)
+      child[key] = mergeOptions(child[key] || {}, value, visited)
     } else {
       child[key] = value
     }
-- 
2.34.1

