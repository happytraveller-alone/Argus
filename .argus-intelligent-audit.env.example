# Argus intelligent-audit / AgentFlow backend environment
# Copy to .argus-intelligent-audit.env and replace every placeholder.
# This file is the reset/start LLM source for Argus intelligent audit.
# Compose injects it directly into backend; UI/API do not write it.

# Security: required by backend runtime; generated/stored only in this dedicated env file.
# Generate with: openssl rand -hex 32
SECRET_KEY=REPLACE_ME_WITH_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# LLM / intelligent-audit required configuration.
LLM_PROVIDER=openai_compatible
LLM_API_KEY=REPLACE_ME_WITH_REAL_API_KEY
LLM_MODEL=REPLACE_ME_WITH_MODEL
LLM_BASE_URL=https://api.openai.com/v1
LLM_TIMEOUT=150
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# Agent audit defaults.
AGENT_ENABLED=true
AGENT_MAX_ITERATIONS=5
AGENT_TIMEOUT=1800
ENABLE_PARALLEL_ANALYSIS=true
ENABLE_PARALLEL_VERIFICATION=true
ANALYSIS_MAX_WORKERS=5
VERIFICATION_MAX_WORKERS=3

# Optional provider-specific settings can be added below when needed.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OLLAMA_BASE_URL=http://localhost:11434/v1
