{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "opengrep",
          "version": "0.1.0",
          "rules": [
            {
              "id": "python.sql.injection",
              "name": "SqlInjection",
              "shortDescription": { "text": "Possible SQL injection" },
              "defaultConfiguration": { "level": "error" }
            },
            {
              "id": "python.xss.reflected",
              "name": "ReflectedXss",
              "shortDescription": { "text": "Reflected XSS" },
              "defaultConfiguration": { "level": "error" }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "python.sql.injection",
          "level": "error",
          "message": { "text": "User input flows into SQL query without sanitization." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/db.py" },
                "region": { "startLine": 42 }
              }
            }
          ]
        },
        {
          "ruleId": "python.xss.reflected",
          "level": "error",
          "message": { "text": "User-controlled data rendered without escaping." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/views.py" },
                "region": { "startLine": 99 }
              }
            }
          ]
        }
      ]
    }
  ]
}
