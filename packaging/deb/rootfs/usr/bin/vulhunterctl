#!/usr/bin/env bash
set -euo pipefail

ENV_FILE="/etc/vulhunter/vulhunter.env"
DEFAULT_COMPOSE="/etc/vulhunter/docker-compose.prod.yml"
CN_COMPOSE="/etc/vulhunter/docker-compose.prod.cn.yml"
OVERRIDE_COMPOSE="/etc/vulhunter/docker-compose.override.yml"
PROJECT_NAME="vulhunter"

load_env() {
  if [[ -f "$ENV_FILE" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "$ENV_FILE"
    set +a
  fi
}

compose_file() {
  load_env
  case "${VULHUNTER_COMPOSE_VARIANT:-prod_cn}" in
    prod)
      echo "$DEFAULT_COMPOSE"
      ;;
    prod_cn|cn)
      echo "$CN_COMPOSE"
      ;;
    *)
      echo "$CN_COMPOSE"
      ;;
  esac
}

compose_cmd() {
  local cfg
  cfg="$(compose_file)"
  docker compose \
    --project-name "$PROJECT_NAME" \
    --env-file "$ENV_FILE" \
    -f "$cfg" \
    -f "$OVERRIDE_COMPOSE"
}

usage() {
  cat <<USAGE
Usage: vulhunterctl <start|stop|restart|status|logs|ps|ports|env-show|purge-data>
USAGE
}

cmd="${1:-}"
case "$cmd" in
  start)
    compose_cmd up -d
    ;;
  stop)
    compose_cmd down
    ;;
  restart)
    compose_cmd up -d
    ;;
  status)
    systemctl status vulhunter --no-pager || true
    compose_cmd ps
    ;;
  logs)
    mode="${2:---compose}"
    if [[ "$mode" == "--journal" ]]; then
      journalctl -u vulhunter -n 200 --no-pager
    else
      compose_cmd logs --tail=200
    fi
    ;;
  ps)
    compose_cmd ps
    ;;
  ports)
    load_env
    echo "frontend: http://localhost:${VULHUNTER_FRONTEND_PORT:-3000}"
    echo "backend : http://localhost:${VULHUNTER_BACKEND_PORT:-8000}/docs"
    ;;
  env-show)
    cat "$ENV_FILE"
    ;;
  purge-data)
    if [[ "${2:-}" != "--with-volumes" ]]; then
      echo "Use: vulhunterctl purge-data --with-volumes"
      exit 1
    fi
    compose_cmd down -v
    ;;
  *)
    usage
    exit 1
    ;;
esac
