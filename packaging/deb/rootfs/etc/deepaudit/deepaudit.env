# DeepAudit package environment
DEEPAUDIT_COMPOSE_VARIANT=prod_cn
DEEPAUDIT_IMAGE_TAG=3.0.4

DEEPAUDIT_FRONTEND_PORT=3000
DEEPAUDIT_BACKEND_PORT=8000

LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_KEY=your-api-key-here
