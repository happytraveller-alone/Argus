# VulHunter package environment
VULHUNTER_COMPOSE_VARIANT=prod_cn
VULHUNTER_IMAGE_TAG=3.0.4

CN_RETRY_COUNT=3
OFFICIAL_RETRY_COUNT=3
RETRY_INTERVAL_SECONDS=5

DOCKERHUB_LIBRARY_MIRROR=docker.m.daocloud.io/library
GHCR_REGISTRY=ghcr.nju.edu.cn
UV_IMAGE=ghcr.nju.edu.cn/astral-sh/uv:latest
SANDBOX_BASE_IMAGE=docker.m.daocloud.io/python:3.11-bullseye
SANDBOX_IMAGE=ghcr.nju.edu.cn/lintsinghua/vulhunter-sandbox:latest

VULHUNTER_FRONTEND_PORT=3000
VULHUNTER_BACKEND_PORT=8000

LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=

MCP_CODEBADGER_ENABLED=true
MCP_CODEBADGER_RUNTIME_MODE=backend_only
MCP_CODEBADGER_BACKEND_URL=http://codebadger-mcp:4242/mcp
MCP_CODEBADGER_SANDBOX_URL=
MCP_CODEBADGER_FAILURE_MODE=degrade
JOERN_MCP_URL=http://codebadger-mcp:4242/mcp
